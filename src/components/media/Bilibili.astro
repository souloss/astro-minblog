---
/**
 * Bilibili video embed component
 * Usage: <Bilibili bvid="BV1xx411c7mD" />
 * Or with custom parameters: <Bilibili bvid="BV1xx411c7mD" page={1} />
 */

interface Props {
  bvid: string;
  page?: number;
}

const {
  bvid,
  page = 1,
} = Astro.props;
---

<div class="bilibili-embed-wrapper my-6">
  <div class="relative w-full" style="padding-bottom: 56.25%;">
    <iframe
      src={`https://player.bilibili.com/player.html?bvid=${bvid}&page=${page}&high_quality=1&danmaku=0&autoplay=0`}
      class="absolute top-0 left-0 w-full h-full rounded-lg border border-border"
      allowfullscreen="true"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      loading="lazy"
    >
    </iframe>
  </div>
</div>

<style>
  .bilibili-embed-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 0.5rem;
    background: var(--color-muted, #e6e6e6);
  }

  :global(html[data-theme="dark"]) .bilibili-embed-wrapper {
    background: var(--color-muted, #343f60);
  }
</style>