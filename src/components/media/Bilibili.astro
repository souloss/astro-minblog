---
/**
 * Bilibili video embed component
 * Usage: <Bilibili bvid="BV1xx411c7mD" />
 */

interface Props {
  bvid: string;
  page?: number;
}

const {
  bvid,
  page = 1,
} = Astro.props;
---

<div class="bilibili-embed-wrapper my-6">
  <div class="relative w-full" style="padding-bottom: 56.25%;">
    <div class="bilibili-placeholder absolute inset-0 flex items-center justify-center rounded-lg border border-border bg-muted/30">
      <svg class="size-10 animate-pulse text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <polygon points="5 3 19 12 5 21 5 3" />
      </svg>
    </div>
    <iframe
      src={`https://player.bilibili.com/player.html?bvid=${bvid}&page=${page}&high_quality=1&danmaku=0&autoplay=0`}
      class="bilibili-iframe absolute top-0 left-0 w-full h-full rounded-lg border border-border"
      allowfullscreen="true"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      loading="lazy"
      onload="this.previousElementSibling.style.display='none'"
    >
    </iframe>
  </div>
</div>

<style>
  .bilibili-embed-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 0.5rem;
  }
</style>
