---
import type { GetStaticPaths } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/nav/Header.astro";
import Footer from "@/components/nav/Footer.astro";
import Main from "@/layouts/Main.astro";
import { FRIENDS } from "@/data/friends";
import { SITE } from "@/config";
import { t } from "@/utils/i18n";

export const getStaticPaths = (async () => {
  return [{ params: { lang: "zh" } }, { params: { lang: "en" } }];
}) satisfies GetStaticPaths;

const { lang } = Astro.params as { lang: "zh" | "en" };
---

<Layout lang={lang} title={`${t("friends.title", lang)} | ${SITE.title}`}>
  <Header lang={lang} />
  <Main
    pageTitle={t("friends.title", lang)}
    pageDesc={t("friends.desc", lang)}
    data-lang={lang}
  >
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        FRIENDS.map(friend => (
          <a
            href={friend.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex gap-4 rounded-lg border border-border bg-background/50 p-4 transition-colors hover:border-accent hover:bg-muted/30"
          >
            {friend.avatar && (
              <img
                src={friend.avatar}
                alt=""
                class="size-12 shrink-0 rounded-full object-cover"
                width="48"
                height="48"
              />
            )}
            <div class="min-w-0 flex-1">
              <div class="font-semibold text-foreground">{friend.name}</div>
              {friend.description && (
                <div class="text-muted-foreground mt-1 line-clamp-2 text-sm">
                  {friend.description}
                </div>
              )}
            </div>
          </a>
        ))
      }
    </div>
  </Main>
  <Footer lang={lang} />
</Layout>
