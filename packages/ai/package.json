{
  "name": "@astro-minimax/ai",
  "version": "0.9.0",
  "type": "module",
  "description": "Vendor-agnostic AI integration package with full RAG pipeline for astro-minimax blogs — supports OpenAI, Cloudflare AI, and custom providers.",
  "author": "Souloss",
  "license": "MIT",
  "keywords": [
    "astro",
    "ai",
    "llm",
    "rag",
    "openai",
    "cloudflare-ai",
    "vector-search",
    "streaming",
    "chatbot"
  ],
  "homepage": "https://github.com/souloss/astro-minimax#readme",
  "bugs": {
    "url": "https://github.com/souloss/astro-minimax/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/souloss/astro-minimax",
    "directory": "packages/ai"
  },
  "bin": {
    "astro-ai-dev": "./dist/server/dev-server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.js"
    },
    "./search": {
      "types": "./dist/search/index.d.ts",
      "import": "./dist/search/index.js"
    },
    "./intelligence": {
      "types": "./dist/intelligence/index.d.ts",
      "import": "./dist/intelligence/index.js"
    },
    "./prompt": {
      "types": "./dist/prompt/index.d.ts",
      "import": "./dist/prompt/index.js"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "import": "./dist/data/index.js"
    },
    "./fact-registry": {
      "types": "./dist/fact-registry/index.d.ts",
      "import": "./dist/fact-registry/index.js"
    },
    "./stream": {
      "types": "./dist/stream/index.d.ts",
      "import": "./dist/stream/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./extensions": {
      "types": "./dist/extensions/index.d.ts",
      "import": "./dist/extensions/index.js"
    },
    "./structured-output": {
      "types": "./dist/structured-output/index.d.ts",
      "import": "./dist/structured-output/index.js"
    },
    "./components/ChatPanel": {
      "types": "./dist/components/ChatPanel.d.ts",
      "import": "./dist/components/ChatPanel.js"
    },
    "./components/AIChatContainer": {
      "types": "./dist/components/AIChatContainer.d.ts",
      "import": "./dist/components/AIChatContainer.js"
    },
    "./components/AIChatWidget.astro": "./dist/components/AIChatWidget.astro",
    "./styles/source.css": "./src/styles/source.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "src/styles/",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:watch": "node scripts/build.mjs --watch",
    "build:components": "node scripts/build-components.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@astro-minimax/notify": "workspace:*",
    "ai": "^6.0.116",
    "workers-ai-provider": "^3.1.2",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "undici": "^6.0.0"
  },
  "peerDependencies": {
    "@ai-sdk/react": "^3.0.0",
    "@cloudflare/workers-types": "^4.0.0",
    "preact": "^10.0.0",
    "shiki": "^1.0.0 || ^2.0.0",
    "mermaid": "^11.0.0",
    "markmap-lib": "^0.18.0",
    "markmap-view": "^0.18.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/react": {
      "optional": true
    },
    "preact": {
      "optional": true
    },
    "shiki": {
      "optional": true
    },
    "mermaid": {
      "optional": true
    },
    "markmap-lib": {
      "optional": true
    },
    "markmap-view": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
