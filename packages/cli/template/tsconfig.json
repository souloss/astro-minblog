{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", "node_modules"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@astro-minimax/core/types": ["../../core/src/types.ts"],
      "@astro-minimax/ai": ["../../ai/src/index.ts"],
      "@astro-minimax/ai/*": ["../../ai/src/*"],
      "@astro-minimax/notify": ["../../notify/src/index.ts"],
      "@astro-minimax/notify/*": ["../../notify/src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": ["@cloudflare/workers-types"]
  }
}
