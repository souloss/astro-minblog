{
  "name": "my-blog",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -n \"astro,ai\" -c \"blue,green\" \"astro dev\" \"pnpm exec astro-ai-dev\"",
    "dev:astro": "astro dev",
    "dev:ai": "pnpm exec astro-ai-dev",
    "build": "astro check && astro build && pagefind --site dist",
    "clean": "rm -rf dist .astro node_modules/.vite node_modules/.cache",
    "preview": "wrangler pages dev dist",
    "preview:astro": "astro preview",
    "lint": "eslint .",
    "cli": "astro-minimax",
    "ai:process": "astro-minimax ai process",
    "ai:seo": "astro-minimax ai seo",
    "ai:summary": "astro-minimax ai summary",
    "ai:eval": "astro-minimax ai eval",
    "ai:profile:build": "astro-minimax ai profile build",
    "ai:profile:context": "astro-minimax ai profile context",
    "ai:profile:voice": "astro-minimax ai profile voice",
    "ai:profile:facts": "astro-minimax ai profile facts",
    "ai:profile:report": "astro-minimax ai profile report",
    "ai:facts:build": "astro-minimax ai facts build",
    "ai:facts:validate": "astro-minimax ai facts validate",
    "ai:facts:status": "astro-minimax ai facts status",
    "ai:extensions:build": "astro-minimax ai extensions build",
    "ai:extensions:validate": "astro-minimax ai extensions validate",
    "ai:extensions:status": "astro-minimax ai extensions status",
    "ai:extensions:load": "astro-minimax ai extensions load",
    "post:new": "astro-minimax post new",
    "post:list": "astro-minimax post list",
    "post:stats": "astro-minimax post stats",
    "data:status": "astro-minimax data status",
    "data:clear": "astro-minimax data clear",
    "hooks:install": "astro-minimax hooks install",
    "hooks:uninstall": "astro-minimax hooks uninstall",
    "hooks:status": "astro-minimax hooks status"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@ai-sdk/react": "^3.0.118",
    "@astro-minimax/ai": "^0.9.2",
    "@astro-minimax/core": "^0.9.2",
    "@astro-minimax/notify": "^0.9.2",
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/preact": "^5.0.0",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@resvg/resvg-js": "^2.6.2",
    "@shikijs/rehype": "^4.0.2",
    "@tailwindcss/vite": "^4.2.1",
    "ai": "^6.0.116",
    "astro": "^6.0.0",
    "dayjs": "^1.11.19",
    "lodash.kebabcase": "^4.1.1",
    "markmap-lib": "^0.18.11",
    "mermaid": "^11.12.3",
    "preact": "^10.29.0",
    "qrcode": "^1.5.4",
    "rehype-katex": "^7.0.1",
    "remark-emoji": "^5.0.2",
    "remark-github-alerts": "^0.1.1",
    "remark-math": "^6.0.0",
    "satori": "^0.25.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@astro-minimax/cli": "^0.9.2",
    "@astrojs/check": "^0.9.7",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@pagefind/default-ui": "^1.4.0",
    "@shikijs/transformers": "^4.0.2",
    "@types/lodash.kebabcase": "^4.1.9",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.3",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^16.5.0",
    "pagefind": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "wrangler": "^4.73.0"
  }
}
