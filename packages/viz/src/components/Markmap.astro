---
/**
 * Markmap component for direct use in Astro templates.
 * 
 * IMPORTANT: For markdown code blocks, use ```markmap syntax directly.
 * The remark-markmap plugin will automatically transform it.
 * 
 * This component is for programmatic use in .astro files.
 */

import { randomUUID } from "node:crypto";

interface Props {
  /** Markdown content for the mindmap */
  content: string;
  /** Optional ID for the wrapper element */
  id?: string;
  /** Markmap options (colorFreezeLevel, etc.) */
  options?: Record<string, unknown>;
}

const { content, id, options = {} } = Astro.props;
const uniqueId = id || `markmap-${randomUUID()}`;

// remark-markmap expects JSON scripts with root and options
// We need to transform markdown to tree structure first
// For simplicity, we output the markdown and let the client-side handle it
---

<div class="markmap-wrap" id={uniqueId}>
  <script type="application/json" class="markmap-root" set:html={JSON.stringify(content)} />
  <script type="application/json" class="markmap-options" set:html={JSON.stringify(options)} />
</div>

<style is:global>
  /* Markmap wrapper styles - matching remark-markmap */
  .markmap-wrap {
    position: relative;
    height: max-content;
    width: 100%;
    min-height: 300px;
    margin: 1.5rem 0;
  }

  .markmap-wrap.fullscreen {
    background: #ffffff;
  }

  :global(html[data-theme="dark"]) .markmap-wrap.fullscreen,
  :global(html.markmap-dark) .markmap-wrap.fullscreen {
    background: #1a1a1a;
  }

  .markmap-wrap > svg {
    width: 100%;
    height: auto;
    margin: 0;
    padding: 0;
  }

  .markmap-wrap.fullscreen > svg {
    height: 100% !important;
  }

  /* Toolbar positioning */
  .mm-toolbar {
    position: absolute;
    right: 0.5em;
    bottom: 0.5em;
  }
</style>