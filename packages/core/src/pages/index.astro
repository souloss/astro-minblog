---
// Static redirect: meta refresh + link for default locale (Chinese)
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content="0;url=/zh/" />
    <link rel="canonical" href="/zh/" />
    <title>Redirecting...</title>
  </head>
  <body>
    <p>Redirecting to <a href="/zh/">Chinese version</a>...</p>
  </body>
</html>
