---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import Main from "../../../layouts/Main.astro";
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/nav/Header.astro";
import Footer from "../../../components/nav/Footer.astro";
import PostsContainer from "../../../components/ui/PostsContainer.astro";
import Pagination from "../../../components/nav/Pagination.astro";
import {
  getCategoryTree,
  getAllCategoryPaths,
  findCategoryNode,
} from "../../../utils/getUniqueCategories";
import type { CategoryTreeNode } from "../../../utils/getUniqueCategories";
import getPostsByCategory from "../../../utils/getPostsByCategory";
import { getPostsByLang } from "../../../utils/getPostsByLang";
import {
  getCategoryPathSegments,
  getCategoryUrl,
} from "../../../utils/getCategoryPath";
import IconArchive from "../../../assets/icons/IconArchive.svg";
import IconChevronRight from "../../../assets/icons/IconChevronRight.svg";
import { SITE } from "virtual:astro-minimax/config";
import { t } from "../../../utils/i18n";

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const result: Array<{
    params: { lang: string; path: string };
    props: { category: string; page: Page<CollectionEntry<"blog">> };
  }> = [];

  for (const lang of ["zh", "en"] as const) {
    const langPosts = getPostsByLang(posts, lang);
    const tree = getCategoryTree(langPosts);
    const allCategoryPaths = getAllCategoryPaths(tree);

    for (const category of allCategoryPaths) {
      const categoryPosts = getPostsByCategory(langPosts, category);
      const totalPages = Math.ceil(
        categoryPosts.length / SITE.postPerPage
      ) || 1;

      for (let page = 1; page <= totalPages; page++) {
        const start = (page - 1) * SITE.postPerPage;
        const pageData = categoryPosts.slice(start, start + SITE.postPerPage);
        const pathSegments = getCategoryPathSegments(category, page);
        const pathParam = pathSegments.join("/");

        result.push({
          params: { lang, path: pathParam },
          props: {
            category,
            page: {
              data: pageData,
              currentPage: page,
              lastPage: totalPages,
              url: {
                prev: page > 1 ? getCategoryUrl(lang, category, page - 1) : undefined,
                next:
                  page < totalPages
                    ? getCategoryUrl(lang, category, page + 1)
                    : undefined,
              },
            } as Page<CollectionEntry<"blog">>,
          },
        });
      }
    }
  }

  return result;
}) satisfies GetStaticPaths;

type Props = { category: string; page: Page<CollectionEntry<"blog">> };
const { category, page } = Astro.props as Props;
const lang = (Astro.params.lang ?? "zh") as "zh" | "en";

// Parse category path segments for breadcrumb
const categoryParts = category.split("/");

// Get the category tree to find children and parent info
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const langPosts = getPostsByLang(allPosts, lang);
const tree = getCategoryTree(langPosts);
const currentNode = findCategoryNode(tree, category);
const children = currentNode?.children ?? [];

function countAll(node: CategoryTreeNode): number {
  return node.count + node.children.reduce((s, c) => s + countAll(c), 0);
}
---

<Layout
  lang={lang}
  title={`${t("search.category", lang)}: ${category} | ${SITE.title}`}
>
  <Header lang={lang} />
  <Main
    pageTitle={[`${t("search.category", lang)}:`, category]}
    titleTransition={category}
    pageDesc={t("main.categoryDesc", lang).replace("{category}", category)}
  >
    <!-- Category Breadcrumb (for nested categories) -->
    {categoryParts.length > 1 && (
      <nav class="mb-4 flex items-center gap-1.5 text-sm text-muted" aria-label="category breadcrumb">
        <a
          href={`/${lang}/categories/`}
          class="transition-colors hover:text-accent"
        >
          {t("nav.categories", lang)}
        </a>
        {categoryParts.slice(0, -1).map((part, i) => {
          const parentPath = categoryParts.slice(0, i + 1).join("/");
          return (
            <>
              <IconChevronRight class="size-3 opacity-40" />
              <a
                href={getCategoryUrl(lang, parentPath)}
                class="transition-colors hover:text-accent"
              >
                {part}
              </a>
            </>
          );
        })}
        <IconChevronRight class="size-3 opacity-40" />
        <span class="font-medium text-foreground">{categoryParts[categoryParts.length - 1]}</span>
      </nav>
    )}

    <!-- Category Badge -->
    <div class="mb-6 flex items-center gap-3">
      <div class="flex size-10 items-center justify-center rounded-xl bg-accent/10 text-accent">
        <IconArchive class="size-5" />
      </div>
      <div class="flex items-center gap-2 text-sm text-muted">
        <span class="rounded-lg bg-accent/10 px-2.5 py-1 text-xs font-medium text-accent">
          {page.data.length} {t("unit.posts", lang)}
        </span>
        {page.lastPage > 1 && (
          <span class="opacity-60">
            {t("archives.page", lang).replace("{current}", String(page.currentPage)).replace("{total}", String(page.lastPage))}
          </span>
        )}
      </div>
    </div>

    <!-- Subcategory Links -->
    {children.length > 0 && (
      <div class="mb-6 flex flex-wrap gap-2">
        <span class="text-sm font-medium text-muted">{t("categories.subcategoriesList", lang)}:</span>
        {children.map(child => (
          <a
            href={getCategoryUrl(lang, child.fullPath)}
            class="inline-flex items-center gap-1.5 rounded-lg bg-muted/40 px-2.5 py-1 text-xs font-medium text-foreground-soft transition-colors hover:bg-accent/10 hover:text-accent"
          >
            <IconChevronRight class="size-3 opacity-60" />
            {child.name}
            <span class="opacity-50">({countAll(child)})</span>
          </a>
        ))}
      </div>
    )}

    <PostsContainer posts={page.data} lang={lang} />
  </Main>

  <Pagination page={page} lang={lang} />

  <Footer lang={lang} noMarginTop={page.lastPage > 1} />
</Layout>