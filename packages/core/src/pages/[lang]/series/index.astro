---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Main from "../../../layouts/Main.astro";
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/nav/Header.astro";
import Footer from "../../../components/nav/Footer.astro";
import { getPostsByLang } from "../../../utils/getPostsByLang";
import { getSeriesFromPosts } from "../../../utils/getSeriesData";
import IconSeries from "../../../assets/icons/IconSeries.svg";
import IconArchive from "../../../assets/icons/IconArchive.svg";
import IconArrowRight from "../../../assets/icons/IconArrowRight.svg";
import { SITE } from "virtual:astro-minimax/config";
import { t } from "../../../utils/i18n";

export const getStaticPaths = (() => [
  { params: { lang: "zh" } },
  { params: { lang: "en" } },
]) satisfies GetStaticPaths;

const { lang } = Astro.params as { lang: "zh" | "en" };

const posts = await getCollection("blog");
const langPosts = getPostsByLang(posts, lang);
const seriesList = getSeriesFromPosts(langPosts);

import dayjs from "dayjs";
import utcPlugin from "dayjs/plugin/utc";
import timezonePlugin from "dayjs/plugin/timezone";

dayjs.extend(utcPlugin);
dayjs.extend(timezonePlugin);

const totalSeries = seriesList.length;
const totalPosts = seriesList.reduce((sum, s) => sum + s.totalPosts, 0);
---

<Layout lang={lang} title={`${t("series.title", lang)} | ${SITE.title}`}>
  <Header lang={lang} />
  <Main pageTitle={t("series.title", lang)} pageDesc={t("series.desc", lang)} wide={true}>
    <!-- Stats Overview -->
    <div class="mb-8 flex items-center gap-6 text-sm text-muted">
      <div class="flex items-center gap-2">
        <IconSeries class="size-4 text-accent" />
        <span>{totalSeries} {t("series.count", lang)}</span>
      </div>
      <div class="flex items-center gap-2">
        <IconArchive class="size-4 text-accent" />
        <span>{totalPosts} {t("series.totalPosts", lang)}</span>
      </div>
    </div>

    {
      seriesList.length > 0 ? (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {seriesList.map((series, index) => {
            const dateStr =
              lang === "zh"
                ? dayjs(series.latestDate)
                    .tz(SITE.timezone)
                    .format("YYYY 年 M 月 D 日")
                : dayjs(series.latestDate)
                    .tz(SITE.timezone)
                    .format("MMM D, YYYY");

            const countStr = String(series.totalPosts).padStart(2, "0");
            const delay = Math.min(index * 80, 400);

            return (
              <a
                href={`/${lang}/series/${encodeURIComponent(series.slug)}/`}
                class="card-animate group block overflow-hidden rounded-2xl border border-border/50 bg-card/60 p-5 backdrop-blur-md transition-all duration-300 ease-out hover:border-accent/25 hover:bg-card-hover hover:shadow-xl hover:shadow-shadow-elevated/10 hover:-translate-y-1 sm:p-6"
                style={`animation-delay: ${delay}ms`}
              >
                {/* Header */}
                <div class="flex items-start gap-3">
                  <div class="flex size-10 shrink-0 items-center justify-center rounded-xl bg-accent/10 text-accent transition-colors group-hover:bg-accent/15">
                    <IconSeries class="size-5" />
                  </div>
                  <div class="min-w-0 flex-1">
                    <h2 class="truncate text-lg font-semibold text-foreground transition-colors group-hover:text-accent">
                      {series.name}
                    </h2>
                    <div class="mt-1 flex items-center gap-2 text-sm text-muted">
                      <span class="rounded-lg bg-accent/10 px-2.5 py-1 text-xs font-medium text-accent">
                        {countStr} {t("series.articlesShort", lang)}
                      </span>
                    </div>
                  </div>
                </div>

                {/* Description */}
                {series.description && (
                  <p class="mt-4 line-clamp-2 text-sm leading-relaxed text-foreground-soft">
                    {series.description}
                  </p>
                )}

                {/* Post Preview */}
                <ul class="mt-4 space-y-1.5 border-t border-border/50 pt-4">
                  {series.posts.slice(0, 3).map((post, idx) => (
                    <li class="flex items-center gap-2 text-sm text-foreground-soft">
                      <span class="w-5 shrink-0 text-right font-mono text-xs opacity-50">
                        {String(idx + 1).padStart(2, "0")}
                      </span>
                      <span class="truncate">{post.data.title}</span>
                    </li>
                  ))}
                  {series.totalPosts > 3 && (
                    <li class="pl-7 text-xs text-muted">
                      +{series.totalPosts - 3} {t("series.moreArticles", lang)}…
                    </li>
                  )}
                </ul>

                {/* Footer */}
                <div class="mt-4 flex items-center justify-between border-t border-border/50 pt-4">
                  <div class="flex items-center gap-2 text-xs text-muted">
                    <span class="inline-block size-1.5 rounded-full bg-accent animate-pulse"></span>
                    <span>{t("series.latestUpdate", lang)}: {dateStr}</span>
                  </div>
                  <IconArrowRight class="size-5 shrink-0 text-muted/50 transition-all duration-300 group-hover:translate-x-1 group-hover:text-accent group-hover:opacity-100" />
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center py-16 text-center">
          <div class="flex size-16 items-center justify-center rounded-2xl bg-muted/30">
            <IconSeries class="size-8 text-muted" />
          </div>
          <p class="mt-4 text-muted">{t("series.noSeries", lang)}</p>
        </div>
      )
    }
  </Main>
  <Footer lang={lang} />
</Layout>
