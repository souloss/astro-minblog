---
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/nav/Header.astro";
import Footer from "../../components/nav/Footer.astro";
import Main from "../../layouts/Main.astro";
import GithubCard from "../../components/ui/GithubCard.astro";
import { SITE } from "virtual:astro-minimax/config";
import { t } from "../../utils/i18n";

export const getStaticPaths = (async () => {
  return [{ params: { lang: "zh" } }, { params: { lang: "en" } }];
}) satisfies GetStaticPaths;

const { lang } = Astro.params as { lang: "zh" | "en" };
---

<Layout lang={lang} title={`${t("projects.title", lang)} | ${SITE.title}`}>
  <Header lang={lang} />
  <Main
    pageTitle={t("projects.title", lang)}
    pageDesc={t("projects.desc", lang)}
    data-lang={lang}
  >
    <div class="grid gap-6 sm:grid-cols-2">
      {
        SITE.projects.map(project => (
          <div class:list={[project.featured && "sm:col-span-2"]}>
            <GithubCard repo={project.repo} />
          </div>
        ))
      }
    </div>
  </Main>
  <Footer lang={lang} />
</Layout>
