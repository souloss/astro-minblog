---
import { render, type CollectionEntry } from "astro:content";
import Layout from "./Layout.astro";
import Header from "../components/nav/Header.astro";
import Footer from "../components/nav/Footer.astro";
import Tag from "../components/ui/Tag.astro";
import Datetime from "../components/ui/Datetime.astro";
import PostMeta from "../components/ui/PostMeta.astro";
import BackButton from "../components/nav/BackButton.astro";
import BackLink from "../components/nav/BackLink.astro";
import { getLocalizedPostPath, getPostSlug } from "../utils/getPath";
import { t } from "../utils/i18n";
import { slugifyStr } from "../utils/slugify";
import IconChevronLeft from "../assets/icons/IconChevronLeft.svg";
import IconChevronRight from "../assets/icons/IconChevronRight.svg";
import { SITE } from "virtual:astro-minimax/config";
import aiSeo from "virtual:astro-minimax/ai-seo";
import FloatingTOC from "../components/blog/FloatingTOC.astro";
import FloatingSeriesNav from "../components/blog/FloatingSeriesNav.astro";
import InlineTOC from "../components/blog/InlineTOC.astro";
import Comments from "../components/blog/Comments.astro";

import RelatedPosts from "../components/blog/RelatedPosts.astro";
import Copyright from "../components/blog/Copyright.astro";
import SeriesNav from "../components/blog/SeriesNav.astro";
import { getRelatedPosts } from "../utils/getRelatedPosts";
import { getReadingTime } from "../utils/getReadingTime";
import { getCategoryUrl } from "../utils/getCategoryPath";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
  lang?: string;
};

const { post, posts, lang = "zh" } = Astro.props;

const {
  title,
  author,
  description,
  cover,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  category,
  series,
} = post.data;

const { Content, headings } = await render(post);
const { minutes: readingMinutes, words: wordCount } = getReadingTime(
  post.body ?? ""
);

// Banner image: 封面图片用于文章页展示，优先使用 cover，fallback 到 ogImage
let bannerImageUrl: string | undefined;
const bannerImage = cover || initOgImage;
if (bannerImage && typeof bannerImage === "object" && "src" in bannerImage) {
  bannerImageUrl = bannerImage.src;
} else if (typeof bannerImage === "string" && bannerImage.startsWith("http")) {
  bannerImageUrl = bannerImage;
}

// OG meta image: includes dynamic fallback for social sharing
let ogImageUrl: string | undefined = bannerImageUrl;
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `/${lang}/posts/${getPostSlug(post.id)}.png`;
}

const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const slug = getPostSlug(post.id);
const aiSummaryKey = `${lang}/${slug}`;
const aiSeoData = aiSeo?.articles?.[aiSummaryKey]?.data;

// SEO data with ai-seo priority
const seoDescription = aiSeoData?.metaDescription || description;
const seoKeywords = aiSeoData?.keywords || [];
const ogDescription = aiSeoData?.ogDescription || description;

const articleContext = {
  slug,
  title: title ?? '',
  categories: category ? [category] : [],
  summary: seoDescription ?? description ?? '',
  abstract: undefined,
  keyPoints: [],
};

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description: seoDescription,
  keywords: seoKeywords,
  ogDescription,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
  lang,
  tags,
  articleContext,
};

const breadcrumbList = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: lang === "zh" ? "首页" : "Home",
      item: `${SITE.website}${lang}/`,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: lang === "zh" ? "文章" : "Posts",
      item: `${SITE.website}${lang}/posts/`,
    },
    ...(category
      ? [
          {
            "@type": "ListItem",
            position: 3,
            name: category,
            item: `${SITE.website.replace(/\/$/, "")}${getCategoryUrl(lang, category)}`,
          },
          {
            "@type": "ListItem",
            position: 4,
            name: title,
          },
        ]
      : [
          {
            "@type": "ListItem",
            position: 3,
            name: title,
          },
        ]),
  ],
};

/* ========== Prev/Next Posts (Series-aware) ========== */

const seriesPosts = series
  ? posts
      .filter(p => p.data.series?.name === series.name)
      .sort((a, b) => (a.data.series?.order ?? 0) - (b.data.series?.order ?? 0))
  : null;

const navList = (seriesPosts ?? posts).map(
  ({ data: { title }, id, filePath }) => ({
    id,
    title,
    filePath,
  })
);

const currentPostIndex = navList.findIndex(a => a.id === post.id);
const prevPost = currentPostIndex > 0 ? navList[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex >= 0 && currentPostIndex < navList.length - 1
    ? navList[currentPostIndex + 1]
    : null;
---

<Layout {...layoutProps}>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbList)}
  />
  <Header lang={lang} />

  <BackButton />
  <main
    id="main-content"
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
    data-pagefind-body
  >
    {/* Pagefind filter metadata (hidden, used for search filtering) */}
    <div class="hidden">
      {category && <span data-pagefind-filter="category">{category}</span>}
      <span data-pagefind-filter="lang">{lang}</span>
      {tags?.map((tag: string) => <span data-pagefind-filter="tag">{tag}</span>)}
    </div>

    {/* Article Hero Section */}
    <div class="mb-6">
      {bannerImageUrl && (
        <div class="relative -mx-4 mb-6 h-48 overflow-hidden rounded-xl sm:h-56 md:h-64">
          <img
            src={bannerImageUrl}
            alt={title}
            class="h-full w-full object-cover object-center"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            width="1200"
            height="400"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-background/80 to-transparent" />
        </div>
      )}

      <h1
        transition:name={slugifyStr(title.replaceAll(".", "-"))}
        class="inline-block text-2xl font-bold text-accent sm:text-3xl"
      >
        {title}
      </h1>

      {description && (
        <p class="mt-2 text-base text-foreground-soft leading-relaxed">{description}</p>
      )}

      {/* 元信息 */}
      <div class="mt-4 rounded-lg border border-border/60 bg-card/40 px-4 py-3">
        <PostMeta
          mode="article"
          lang={lang}
          dateStr={pubDatetime ? new Date(pubDatetime).toLocaleDateString(lang === "zh" ? "zh-CN" : "en-US", { year: "numeric", month: "long", day: "numeric" }) : undefined}
          dateIso={pubDatetime?.toISOString()}
          readingMinutes={readingMinutes}
          wordCount={wordCount}
          category={category}
          tags={tags}
        />
      </div>
    </div>

    <InlineTOC headings={headings} lang={lang} />
    <article
      id="article"
      class="app-prose mt-8 w-full max-w-app"
    >
      <Content />
    </article>
    <BackLink />
    <slot name="post-scripts" />
    <FloatingTOC headings={headings} />
    <FloatingSeriesNav post={post} lang={lang} />

    <hr class="my-8 border-dashed" />

    <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
      {
        tags.map((tag: string) => (
          <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" lang={lang} />
        ))
      }
    </ul>

    <Copyright title={title} pubDatetime={pubDatetime} lang={lang} ogImageUrl={ogImageUrl} />

    <hr class="my-6 border-dashed" />

    <div data-pagefind-ignore class="xl:hidden">
      <SeriesNav post={post} lang={lang} />
    </div>

    <!-- Previous/Next Post Buttons -->
    <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        prevPost && (
          <a
            href={getLocalizedPostPath(lang, prevPost.id)}
            class="flex w-full gap-1 hover:opacity-75"
          >
            <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
            <div>
              <span>{t("post.prev", lang)}</span>
              <div class="text-sm text-accent/85">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={getLocalizedPostPath(lang, nextPost.id)}
            class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
          >
            <div>
              <span>{t("post.next", lang)}</span>
              <div class="text-sm text-accent/85">{nextPost.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
          </a>
        )
      }
    </div>

    <RelatedPosts posts={getRelatedPosts(post, posts)} lang={lang} />

    <Comments />
  </main>
  <Footer lang={lang} />
</Layout>

<script is:inline data-astro-rerun>
  (function() {
    let afterSwapHandler = null;

    function addHeadingLinks() {
      const headings = Array.from(
        document.querySelectorAll("h2, h3, h4, h5, h6")
      );
      for (const heading of headings) {
        heading.classList.add("group");
        const link = document.createElement("a");
        link.className =
          "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
        link.href = "#" + heading.id;

        const span = document.createElement("span");
        span.ariaHidden = "true";
        span.innerText = "#";
        link.appendChild(span);
        heading.appendChild(link);
      }
    }

    function cleanup() {
      if (afterSwapHandler) {
        document.removeEventListener("astro:after-swap", afterSwapHandler);
        afterSwapHandler = null;
      }
    }

    document.addEventListener("astro:before-swap", cleanup);

    afterSwapHandler = function() {
      window.scrollTo({ left: 0, top: 0, behavior: "instant" });
    };
    document.addEventListener("astro:after-swap", afterSwapHandler);

    addHeadingLinks();
  })();
</script>
