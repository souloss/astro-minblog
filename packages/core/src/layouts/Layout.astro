---
import { ClientRouter } from "astro:transitions";
import { PUBLIC_GOOGLE_SITE_VERIFICATION } from "astro:env/client";
import { SITE } from "virtual:astro-minimax/config";
import { userDefaults } from "virtual:astro-minimax/preferences-defaults";
import FloatingActions from "../components/nav/FloatingActions.astro";
import SettingsPanel from "../components/nav/SettingsPanel.astro";
import AIChatWidget from "virtual:astro-minimax/ai-widget";
import "virtual:astro-minimax/styles";

const defaultColorScheme = userDefaults?.theme?.colorScheme || "teal";
const defaultRadius = userDefaults?.theme?.radius || "lg";
const defaultLayout = userDefaults?.layout?.postsLayout || "card";
const defaultMode = userDefaults?.theme?.mode || "system";

/** Shape must match ArticleChatContext from @astro-minimax/ai/server */
interface ArticleContext {
  slug: string;
  title: string;
  categories?: string[];
  summary?: string;
  abstract?: string;
  keyPoints?: string[];
  relatedSlugs?: string[];
}

type Props = {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  keywords?: string[];
  ogDescription?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
  lang?: string;
  tags?: string[];
  articleContext?: ArticleContext;
};

const {
  title = SITE.title,
  lang = SITE.lang,
  author = SITE.author,
  profile = SITE.profile,
  description = SITE.desc,
  keywords = [],
  ogDescription: ogDesc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  tags = [],
  articleContext,
} = Astro.props;

const socialDescription = ogDesc || description;

const socialImageURL = new URL(ogImage, Astro.url);

const pathname = Astro.url.pathname;
const altLang = lang === "zh" ? "en" : "zh";
const altPath = pathname.startsWith(`/${lang}/`)
  ? pathname.replace(`/${lang}/`, `/${altLang}/`)
  : null;
const altURL = altPath ? new URL(altPath, Astro.url) : null;

const structuredData = pubDatetime
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: `${title}`,
      description: `${description}`,
      image: `${socialImageURL}`,
      datePublished: pubDatetime.toISOString(),
      ...(modDatetime && { dateModified: modDatetime.toISOString() }),
      author: [
        {
          "@type": "Person",
          name: `${author}`,
          ...(profile && { url: profile }),
        },
      ],
      publisher: {
        "@type": "Organization",
        name: SITE.title,
        url: SITE.website,
      },
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": `${canonicalURL}`,
      },
    }
  : {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: SITE.title,
      description: `${description}`,
      url: SITE.website,
      potentialAction: {
        "@type": "SearchAction",
        target: `${SITE.website}search?q={search_term_string}`,
        "query-input": "required name=search_term_string",
      },
    };
---

<!doctype html>
<html
  dir={SITE.dir}
  lang={lang ?? "zh"}
  class={`${scrollSmooth && "scroll-smooth"}`}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    
    <!-- Reading Mode Fonts - Preload for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.7.0/style.min.css"
      media="print"
      onload="this.media='all'"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=ZCOOL+KuaiLe&family=ZCOOL+XiaoWei&family=Ma+Shan+Zheng&family=Literata:opsz,wght@7..72,400&family=Noto+Serif+SC:wght@400&display=swap"
      media="print"
      onload="this.media='all'"
    />
    
    <!-- PWA manifest + SW: only loaded if files exist (checked at runtime) -->
    <script is:inline>
      (function() {
        function loadManifest() {
          fetch('/manifest.json', { method: 'HEAD' }).then(function(r) {
            if (r.ok) {
              var link = document.createElement('link');
              link.rel = 'manifest';
              link.href = '/manifest.json';
              document.head.appendChild(link);
            }
          }).catch(function() {});
        }
        if ('requestIdleCallback' in window) requestIdleCallback(loadManifest);
        else setTimeout(loadManifest, 100);
      })();
    </script>
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- KaTeX CSS for math equations — loaded async to avoid render blocking -->
    <link
      rel="preload"
      as="style"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
      integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+"
      crossorigin="anonymous"
      data-preload-style
    />
    <script is:inline>
      // Convert preload links to stylesheets after load
      document.querySelectorAll('link[data-preload-style]').forEach(link => {
        link.onload = function() { this.rel = 'stylesheet'; };
      });
    </script>
    <noscript>
      <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
        integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+"
        crossorigin="anonymous"
      />
    </noscript>

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href="/rss.xml"
    />

    <!-- hreflang for multilingual SEO -->
    {
      altURL && (
        <>
          <link
            rel="alternate"
            hreflang={lang === "zh" ? "zh-Hans" : "en"}
            href={canonicalURL}
          />
          <link
            rel="alternate"
            hreflang={altLang === "zh" ? "zh-Hans" : "en"}
            href={altURL}
          />
          <link
            rel="alternate"
            hreflang="x-default"
            href={
              new URL(`/zh${pathname.replace(/^\/(zh|en)/, "")}`, Astro.url)
            }
          />
        </>
      )
    }

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={lang === "zh" ? "zh_CN" : "en_US"} />

    <!-- Article Published/Modified time -->
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <!-- Article Tags -->
    {
      tags.length > 0 &&
        tags.map(tag => <meta property="article:tag" content={tag} />)
    }

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={socialDescription} />
    <meta name="twitter:image" content={socialImageURL} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Google JSON-LD Structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Enable RSS feed auto-discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL("rss.xml", Astro.site)}
    />
    {
      lang && (
        <link
          rel="alternate"
          type="application/rss+xml"
          title={`${SITE.title} (${lang === "zh" ? "中文" : "English"})`}
          href={new URL(`${lang}/rss.xml`, Astro.site)}
        />
      )
    }

    <meta name="theme-color" content="" />

    {
      // If PUBLIC_GOOGLE_SITE_VERIFICATION is set in the environment variable,
      // include google-site-verification tag in the heading
      // Learn more: https://support.google.com/webmasters/answer/9008080#meta_tag_verification&zippy=%2Chtml-tag
      PUBLIC_GOOGLE_SITE_VERIFICATION && (
        <meta
          name="google-site-verification"
          content={PUBLIC_GOOGLE_SITE_VERIFICATION}
        />
      )
    }

    <ClientRouter fallback="animate" />

    {/* Umami Analytics */}
    {
      SITE.umami?.enabled && SITE.umami.websiteId && (
        <script
          is:inline
          defer
          src={SITE.umami.src}
          data-website-id={SITE.umami.websiteId}
        />
      )
    }

    <!-- Minimal inline script to prevent FOUC - sets theme immediately -->
    <script is:inline define:vars={{ defaultColorScheme, defaultRadius, defaultLayout, defaultMode }}>
      (function () {
        // Helper to read sessionStorage backup
        function getStoredThemeBackup() {
          try {
            const stored = sessionStorage.getItem('__astroMinimax_theme');
            if (stored) {
              const data = JSON.parse(stored);
              // Check if backup is recent (within 5 minutes)
              if (data && data.timestamp && Date.now() - data.timestamp < 300000) {
                return data;
              }
            }
          } catch (e) {}
          return null;
        }

        const getPreferencesClient = () => window.__astroMinimaxPreferences;
        const settings = getPreferencesClient()?.loadSettings?.();
        
        // Fall back to sessionStorage backup if preferences client unavailable
        const storedBackup = !settings ? getStoredThemeBackup() : null;
        
        const themeMode = settings?.theme?.mode ?? storedBackup?.mode ?? defaultMode ?? "system";

        function resolveTheme(mode) {
          if (mode === "light") return "light";
          if (mode === "dark") return "dark";
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }

        const themeValue = resolveTheme(themeMode);

        // Set theme immediately to prevent flash
        const root = document.firstElementChild;
        root?.setAttribute("data-theme", themeValue);

        const radiusMap = { sm: "0.5rem", md: "0.75rem", lg: "1rem", xl: "1.5rem" };
        const colorScheme = settings?.theme?.colorScheme ?? storedBackup?.colorScheme ?? defaultColorScheme ?? "teal";
        const layoutMode = settings?.layout?.postsLayout ?? storedBackup?.layout ?? defaultLayout ?? "card";
        const radius = settings?.theme?.radius ?? storedBackup?.radius ?? defaultRadius ?? "lg";

        root?.setAttribute("data-color-scheme", colorScheme);
        root?.setAttribute("data-layout", layoutMode);
        root?.style.setProperty("--card-radius", radiusMap[radius] || "1rem");

        // Store current state as backup for page transitions
        // This ensures theme persists even if preferences client initializes after page swap
        if (typeof sessionStorage !== 'undefined') {
          sessionStorage.setItem('__astroMinimax_theme', JSON.stringify({
            theme: themeValue,
            colorScheme: colorScheme,
            layout: layoutMode,
            radius: radius,
            timestamp: Date.now()
          }));
        }

        // Export minimal API for external script
        window.theme = {
          themeMode,
          themeValue: themeValue,
          getTheme: () => window.theme.themeValue,
          getMode: () => window.theme.themeMode,
          setTheme: val => {
            window.theme.themeMode = val;
            window.theme.themeValue = resolveTheme(val);
          },
          setPreference: () => {
            const preferencesClient = getPreferencesClient();
            const currentSettings = preferencesClient?.loadSettings?.();
            if (!currentSettings || !preferencesClient?.saveSettings) return;
            preferencesClient.saveSettings({
              ...currentSettings,
              theme: {
                ...currentSettings.theme,
                mode: window.theme.themeMode,
              },
            });
          },
          reflectPreference: () => {
            const resolvedTheme = window.theme.themeValue;
            document.firstElementChild?.setAttribute("data-theme", resolvedTheme);
            document.querySelector("#theme-btn")?.setAttribute("aria-label", resolvedTheme);
            const body = document.body;
            if (body) {
              const computedStyles = window.getComputedStyle(body);
              const bgColor = computedStyles.backgroundColor;
              document.querySelector("meta[name='theme-color']")?.setAttribute("content", bgColor);
            }
            requestAnimationFrame(() => {
              window.dispatchEvent(new CustomEvent("themechange", { detail: { isDark: resolvedTheme === "dark", theme: resolvedTheme } }));
            });
          },
          resolveTheme,
          applyMode: mode => {
            window.theme.setTheme(mode);
            window.theme.reflectPreference();
          },
          persistMode: mode => {
            window.theme.setTheme(mode);
            window.theme.setPreference();
            window.theme.reflectPreference();
          },
          syncFromPreferences: () => {
            const latestSettings = getPreferencesClient()?.loadSettings?.();
            const latestMode = latestSettings?.theme?.mode ?? defaultMode ?? "system";
            window.theme.setTheme(latestMode);
          },
        };
        window.theme.reflectPreference();
      })();
    </script>
  </head>
  <body>
    <slot />
    <FloatingActions />
    <SettingsPanel />
    <AIChatWidget lang={lang} articleContext={articleContext} />

    <script is:inline>
      // Theme toggle logic - inlined to ensure bundling works in monorepo setup
      const LIGHT = "light";
      const DARK = "dark";

      function getThemeController() {
        return window.theme;
      }

      function supportsViewTransitions() {
        return "startViewTransition" in document;
      }

      let isTransitioning = false;

      function toggleThemeWithTransition(event) {
        if (isTransitioning) return;

        const currentTheme = getThemeController()?.getTheme?.() ?? LIGHT;
        const newTheme = currentTheme === LIGHT ? DARK : LIGHT;
        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const x = event?.clientX ?? window.innerWidth / 2;
        const y = event?.clientY ?? window.innerHeight / 2;

        if (prefersReducedMotion) {
          getThemeController()?.persistMode?.(newTheme);
          return;
        }

        if (supportsViewTransitions()) {
          isTransitioning = true;
          
          const endRadius = Math.hypot(
            Math.max(x, innerWidth - x),
            Math.max(y, innerHeight - y)
          );
          
          const isGoingDark = newTheme === DARK;
          
          if (isGoingDark) {
            document.documentElement.classList.add('going-dark');
          }
          
          const transition = document.startViewTransition(() => {
            getThemeController()?.persistMode?.(newTheme);
          });
          
          transition.ready.then(() => {
            const clipPath = [
              `circle(0px at ${x}px ${y}px)`,
              `circle(${endRadius}px at ${x}px ${y}px)`
            ];
            
            const animation = document.documentElement.animate(
              {
                clipPath: isGoingDark 
                  ? [clipPath[1], clipPath[0]] 
                  : clipPath,
              },
              {
                duration: 450,
                easing: 'ease-in',
                pseudoElement: isGoingDark
                  ? '::view-transition-old(root)'
                  : '::view-transition-new(root)',
              }
            );
            
            animation.onfinish = () => {
              transition.skipTransition();
              document.documentElement.classList.remove('going-dark');
              isTransitioning = false;
            };
          });
          
          transition.finished.then(() => {
            document.documentElement.classList.remove('going-dark');
            isTransitioning = false;
          });
        } else {
          document.documentElement.classList.add("no-view-transitions");
          getThemeController()?.persistMode?.(newTheme);
          setTimeout(() => {
            document.documentElement.classList.remove("no-view-transitions");
          }, 400);
        }
      }

      function setThemeFeature() {
        getThemeController()?.reflectPreference?.();
        document.querySelector("#theme-btn")?.addEventListener("click", (e) => toggleThemeWithTransition(e));
      }

      setThemeFeature();
      document.addEventListener("astro:after-swap", setThemeFeature);

      document.addEventListener("astro:before-swap", (event) => {
        const bgColor = document.querySelector("meta[name='theme-color']")?.getAttribute("content");
        if (bgColor) {
          event.newDocument.querySelector("meta[name='theme-color']")?.setAttribute("content", bgColor);
        }
      });

      window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", ({ matches: isDark }) => {
        if (getThemeController()?.getMode?.() === "system") {
          getThemeController()?.applyMode?.("system");
        }
      });

      window.addEventListener("astro-minimax:preferences-change", () => {
        getThemeController()?.syncFromPreferences?.();
        getThemeController()?.reflectPreference?.();
      });
    </script>
    <script>
      import "virtual:astro-minimax/preferences-client-init";
    </script>
    <script>
      import '../scripts/lightbox.ts';
    </script>
    <script>
      import '../scripts/reading-position.ts';
    </script>
    <script>
      import '../scripts/web-vitals.ts';
    </script>
    <script>
      import '../actions/init.ts';
    </script>
    <script is:inline>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/sw.js").catch(function() {});
      }
    </script>
  </body>
</html>
