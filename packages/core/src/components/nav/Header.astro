---
import IconX from "../../assets/icons/IconX.svg";
import IconSearch from "../../assets/icons/IconSearch.svg";
import IconMenuDeep from "../../assets/icons/IconMenuDeep.svg";
import IconMoon from "../../assets/icons/IconMoon.svg";
import IconSunHigh from "../../assets/icons/IconSunHigh.svg";
import { SITE } from "virtual:astro-minimax/config";
import { t, type TranslationKey } from "../../utils/i18n";
import { isPathActive } from "../../utils/pathUtils";
import DocSearch from "../search/DocSearch.astro";

const useDocSearch = SITE.search?.provider === 'docsearch' && SITE.search?.docsearch;
const dsConfig = SITE.search?.docsearch;

const { pathname } = Astro.url;
const isActive = (path: string) => isPathActive(path, pathname);

const { lang = "zh" } = Astro.props;

const base = `/${lang}`;

const hrefMap: Record<string, string> = {
  home: `${base}/`,
  posts: `${base}/posts`,
  tags: `${base}/tags`,
  categories: `${base}/categories`,
  series: `${base}/series`,
  projects: `${base}/projects`,
  about: `${base}/about`,
  friends: `${base}/friends`,
  archives: `${base}/archives`,
  search: `${base}/search`,
};

const navItems = (SITE.nav?.items ?? [])
  .filter(i => i.enabled)
  .map(i => ({
    href: hrefMap[i.key] ?? `${base}/${i.key}`,
    label: t(`nav.${i.key}` as TranslationKey, lang),
  }));

const aiEnabled = SITE.ai?.enabled ?? false;
const darkMode = SITE.darkMode ?? true;
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 rounded-md bg-accent px-4 py-2 text-sm font-medium text-white
         backdrop-blur-lg transition-all duration-300 focus:top-4 focus:shadow-lg focus:shadow-accent/25"
>
  Skip to content
</a>

<div id="header-wrapper" class="header-wrapper">
  <header id="main-header" data-nav-overflow="false">
    <nav class="nav-inner">
      {/* LEFT: Logo */}
      <div class="nav-logo">
        <a href={`/${lang}/`} class="nav-logo-link" accesskey="h" title={`${SITE.title} (Alt + H)`}>
          <span class="nav-logo-text">{SITE.title}</span>
        </a>
      </div>

      {/* CENTER: Navigation Links */}
      <ul id="desktop-nav" class="nav-links">
        {
          navItems.map(({ href, label }) => (
            <li>
              <a
                href={href}
                title={label}
                class:list={[
                  "nav-link",
                  { "nav-link--active": isActive(href) },
                ]}
              >
                <span class="nav-link-text">{label}</span>
              </a>
            </li>
          ))
        }
      </ul>

      {/* RIGHT: Widget Area */}
      <div class="nav-widgets">
        {/* Search Chip */}
        {useDocSearch && dsConfig ? (
          <DocSearch
            appId={dsConfig.appId}
            apiKey={dsConfig.apiKey}
            indexName={dsConfig.indexName}
            placeholder={dsConfig.placeholder}
            lang={lang}
          />
        ) : (
          <button
            id="nav-search-trigger"
            class="nav-search-trigger"
            data-search-trigger="nav"
            aria-haspopup="dialog"
            aria-controls="search-command-palette"
            aria-expanded="false"
            title={lang === 'zh' ? '搜索 (⌘K)' : 'Search (⌘K)'}
          >
            <span class="nav-search-trigger__icon" aria-hidden="true">
              <IconSearch class="size-4" />
            </span>
            <span class="nav-search-trigger__label">{lang === 'zh' ? '搜索' : 'Search'}</span>
            <span class="nav-search-trigger__keys" aria-hidden="true">
              <kbd>⌘</kbd>
              <kbd>K</kbd>
            </span>
          </button>
        )}

        {/* Language Switcher */}
        <button
          id="lang-switch-btn"
          class="nav-widget-btn nav-lang-btn"
          title="Switch language"
          aria-label="Switch language"
        >
          <span id="lang-label">EN</span>
        </button>

        {/* AI Chat */}
        {
          aiEnabled && (
            <button
              id="ai-chat-toggle-nav"
              class="nav-widget-btn nav-ai-btn"
              aria-label={t('ai.assistantName', lang)}
              title={t('ai.assistantName', lang)}
            >
              <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 8V4H8" />
                <rect width="16" height="12" x="4" y="8" rx="2" />
                <path d="M2 14h2" />
                <path d="M20 14h2" />
                <path d="M15 13v2" />
                <path d="M9 13v2" />
              </svg>
            </button>
          )
        }

        {/* Immersive Mode */}
        <button
          id="immersive-mode-btn-nav"
          class="nav-widget-btn nav-immersive-btn flex"
          aria-label={lang === 'zh' ? '沉浸模式' : 'Immersive Mode'}
          aria-pressed="false"
          title={lang === 'zh' ? '沉浸模式' : 'Immersive Mode'}
        >
          <svg
            id="immersive-icon-off-nav"
            class="size-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
          </svg>
          <svg
            id="immersive-icon-on-nav"
            class="hidden size-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
          </svg>
        </button>

        {/* Theme Toggle */}
        {
          darkMode && (
            <button
              id="theme-btn"
              class="nav-widget-btn nav-theme-btn"
              title={lang === 'zh' ? '切换主题' : 'Toggle theme'}
              aria-label={lang === 'zh' ? '切换主题' : 'Toggle theme'}
              aria-live="polite"
            >
              <IconMoon class="icon-moon size-4" />
              <IconSunHigh class="icon-sun size-4" />
            </button>
          )
        }

        {/* Settings */}
        <button
          id="settings-btn-nav"
          class="nav-widget-btn nav-settings-btn"
          aria-label={lang === 'zh' ? '偏好设置' : 'Preferences'}
          title={lang === 'zh' ? '偏好设置' : 'Preferences'}
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
        </button>

        {/* Hamburger (mobile) */}
        <button
          id="menu-btn"
          class="hamburger-menu"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <IconX id="close-icon" class="hidden size-5" />
          <IconMenuDeep id="menu-icon" class="size-5" />
        </button>
      </div>
    </nav>
  </header>

  {/* Mobile Menu Dropdown */}
  <div
    id="mobile-menu"
    class="mobile-menu hidden"
  >
    <ul class="mobile-menu-list">
        {
          navItems.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={[
                  "mobile-menu-link",
                  { "mobile-menu-link--active": isActive(href) },
                ]}
              >
                <span>{label}</span>
              </a>
            </li>
          ))
        }
    </ul>
  </div>
</div>

<div class="h-14"></div>

<script>
  import { getGlobalEventManager } from "../../utils/performance";

  type SettingsPanelController = {
    toggle?: () => void;
    toggleReadingMode?: () => void;
  };

  type NavWindow = Window & {
    __aiChatToggle?: () => void;
    __settingsPanel?: SettingsPanelController;
  };

  function initHeader() {
    const manager = getGlobalEventManager();
    const appWindow = window as NavWindow;

    // === Mobile menu toggle ===
    const menuBtn = document.getElementById("menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuIcon = document.getElementById("menu-icon");
    const closeIcon = document.getElementById("close-icon");

    if (menuBtn && mobileMenu && menuIcon && closeIcon) {
      manager.add(menuBtn, "click", () => {
        const openMenu = menuBtn.getAttribute("aria-expanded") === "true";
        menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
        menuBtn.setAttribute("aria-label", openMenu ? "Toggle menu" : "Close menu");
        mobileMenu.classList.toggle("hidden");
        menuIcon.classList.toggle("hidden");
        closeIcon.classList.toggle("hidden");
      });

      // Close menu when clicking outside
      manager.add(document, "click", (e) => {
        if (!mobileMenu.classList.contains("hidden") &&
            !mobileMenu.contains(e.target as Node) &&
            !menuBtn.contains(e.target as Node)) {
          mobileMenu.classList.add("hidden");
          menuBtn.setAttribute("aria-expanded", "false");
          menuBtn.setAttribute("aria-label", "Toggle menu");
          menuIcon.classList.remove("hidden");
          closeIcon.classList.add("hidden");
        }
      });
    }

    // === Auto-hide navbar on scroll (Medium-style) ===
    const headerWrapper = document.getElementById("header-wrapper");
    if (headerWrapper) {
      let lastScrollY = 0;
      let ticking = false;
      const THRESHOLD = 80;

      function updateScroll() {
        const currentY = window.scrollY || window.pageYOffset;
        const mobileMenuOpen = mobileMenu && !mobileMenu.classList.contains("hidden");

        if (!mobileMenuOpen) {
          if (currentY > THRESHOLD && currentY > lastScrollY) {
            headerWrapper.classList.add("nav-scroll-hidden");
          } else {
            headerWrapper.classList.remove("nav-scroll-hidden");
          }
        }
        lastScrollY = currentY;
        ticking = false;
      }

      manager.add(window, "scroll", () => {
        if (!ticking) {
          requestAnimationFrame(updateScroll);
          ticking = true;
        }
      }, { passive: true });
    }

    // === Search trigger (open command palette) ===
    const searchTrigger = document.getElementById("nav-search-trigger");
    if (searchTrigger) {
      manager.add(searchTrigger, "click", () => {
        const palette = (window as NavWindow & { __searchPalette?: { open: () => void } }).__searchPalette;
        if (palette?.open) {
          palette.open();
        } else {
          const lang = document.documentElement.lang?.startsWith("zh") ? "zh" : "en";
          window.location.href = `/${lang}/search`;
        }
      });
    }

    // === AI Chat toggle (nav) ===
    const aiNavBtn = document.getElementById("ai-chat-toggle-nav");
    if (aiNavBtn) {
      manager.add(aiNavBtn, "click", () => {
        if (typeof appWindow.__aiChatToggle === 'function') {
          appWindow.__aiChatToggle();
        }
      });
    }

    // === Settings toggle (nav) ===
    const settingsNavBtn = document.getElementById("settings-btn-nav");
    if (settingsNavBtn) {
      manager.add(settingsNavBtn, "click", () => {
        if (typeof appWindow.__settingsPanel?.toggle === 'function') {
          appWindow.__settingsPanel.toggle();
        }
      });
    }

    // === Settings toggle (mobile menu) ===
    const settingsMobileBtn = document.getElementById("settings-btn-mobile-menu");
    if (settingsMobileBtn) {
      manager.add(settingsMobileBtn, "click", () => {
        if (typeof appWindow.__settingsPanel?.toggle === 'function') {
          appWindow.__settingsPanel.toggle();
        }
      });
    }

    // === Theme toggle (mobile menu) ===
    const themeMobileBtn = document.getElementById("theme-btn-mobile-menu");
    if (themeMobileBtn) {
      manager.add(themeMobileBtn, "click", (e) => {
        // Forward to the main theme button click
        const mainThemeBtn = document.getElementById("theme-btn");
        if (mainThemeBtn) {
          mainThemeBtn.click();
        }
      });
    }

    // === Immersive mode toggle (nav) ===
    const immersiveModeNavBtn = document.getElementById("immersive-mode-btn-nav");
    if (immersiveModeNavBtn) {
      const syncImmersiveModeUI = (active: boolean) => {
        immersiveModeNavBtn.setAttribute("aria-pressed", String(active));
        const iconOff = document.getElementById("immersive-icon-off-nav");
        const iconOn = document.getElementById("immersive-icon-on-nav");
        if (active) {
          immersiveModeNavBtn.classList.add("nav-immersive-btn--active");
          iconOff?.classList.add("hidden");
          iconOn?.classList.remove("hidden");
        } else {
          immersiveModeNavBtn.classList.remove("nav-immersive-btn--active");
          iconOff?.classList.remove("hidden");
          iconOn?.classList.add("hidden");
        }
      };

      const initialActive = document.documentElement.classList.contains("immersive-mode");
      syncImmersiveModeUI(initialActive);

      manager.add(immersiveModeNavBtn, "click", () => {
        if (typeof appWindow.__settingsPanel?.toggleReadingMode === 'function') {
          appWindow.__settingsPanel.toggleReadingMode();
        }
      });

      const observer = new MutationObserver(() => {
        const active = document.documentElement.classList.contains("immersive-mode");
        syncImmersiveModeUI(active);
      });
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      manager.trackObserver(observer, 'mutation');
    }

    // === Immersive mode toggle (mobile menu) ===
    const immersiveModeMobileBtn = document.getElementById("immersive-mode-btn-mobile-menu");
    if (immersiveModeMobileBtn) {
      manager.add(immersiveModeMobileBtn, "click", () => {
        if (typeof appWindow.__settingsPanel?.toggleReadingMode === 'function') {
          appWindow.__settingsPanel.toggleReadingMode();
        }
      });
    }

    // === Language switcher ===
    const langBtns = [
      document.getElementById("lang-switch-btn"),
      document.getElementById("lang-switch-btn-mobile"),
    ];
    const label = document.getElementById("lang-label");
    const labelMobile = document.getElementById("lang-label-mobile");

    const path = window.location.pathname;
    const isZh = path.startsWith("/zh/") || path === "/zh";

    if (label) label.textContent = isZh ? "EN" : "中";
    if (labelMobile) labelMobile.textContent = isZh ? "English" : "中文";

    langBtns.forEach(btn => {
      if (!btn) return;
      manager.add(btn, "click", () => {
        if (isZh) {
          const newPath = path.replace(/^\/zh\/?/, "/en/") || "/en/";
          window.location.href = newPath;
        } else {
          const newPath = path.replace(/^\/en\/?/, "/zh/") || "/zh/";
          window.location.href = newPath;
        }
      });
    });

    // === Overflow detection for responsive nav ===
    function checkNavOverflow() {
      const header = document.getElementById("main-header");
      const desktopNav = document.getElementById("desktop-nav");
      const menuBtnEl = document.getElementById("menu-btn");
      const mobileMenuEl = document.getElementById("mobile-menu");

      if (!header || !desktopNav || !menuBtnEl || !mobileMenuEl) return;

      const container = header.querySelector(".nav-inner") as HTMLElement | null;
      if (!container) return;

      const logo = container.querySelector(".nav-logo") as HTMLElement | null;
      if (!logo) return;

      const containerWidth = container.offsetWidth;
      const logoWidth = logo.offsetWidth;
      const widgets = container.querySelector(".nav-widgets") as HTMLElement | null;
      const widgetsWidth = widgets ? widgets.offsetWidth : 0;

      // Temporarily force nav-links visible to measure content width
      const wasOverflow = header.getAttribute("data-nav-overflow") === "true";
      const prevDisplay = desktopNav.style.display;
      desktopNav.style.display = "flex";

      // Measure the actual content width of nav items
      const navContentWidth = desktopNav.scrollWidth;
      // The available space for nav links = container - logo - widgets - margins
      const marginBuffer = window.innerWidth >= 640 ? 24 : 0;
      const availableSpace = containerWidth - logoWidth - widgetsWidth - marginBuffer;

      // Reset display
      desktopNav.style.display = prevDisplay;

      // Check if nav content overflows the available space
      // Use hysteresis: need 16px more room to exit overflow than to enter
      const enterThreshold = availableSpace;
      const exitThreshold = availableSpace + 16;
      const isOverflow = wasOverflow
        ? navContentWidth > exitThreshold
        : navContentWidth > enterThreshold;

      header.setAttribute("data-nav-overflow", isOverflow ? "true" : "false");

      // CSS rules via :global([data-nav-overflow]) handle display toggling
      // Only need to close mobile menu when not overflowing
      if (!isOverflow && !mobileMenuEl.classList.contains("hidden")) {
        mobileMenuEl.classList.add("hidden");
        menuBtnEl.setAttribute("aria-expanded", "false");
        menuBtnEl.setAttribute("aria-label", "Toggle menu");
        menuIcon?.classList.remove("hidden");
        closeIcon?.classList.add("hidden");
      }
    }

    checkNavOverflow();

    const resizeObserver = new ResizeObserver(() => {
      checkNavOverflow();
    });

    const headerEl = document.getElementById("main-header");
    if (headerEl) {
      resizeObserver.observe(headerEl);
    }
  }

  initHeader();
  document.addEventListener("astro:after-swap", initHeader);
</script>

<style>
  /* === Header Wrapper — Sticky with frosted glass === */
  .header-wrapper {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(251, 249, 244, 0.72);
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    border-bottom: 1px solid rgba(30, 35, 30, 0.06);
    transition: transform 0.25s ease;
    will-change: transform;
  }

  .header-wrapper.nav-scroll-hidden {
    transform: translateY(-100%);
  }

  html[data-theme="dark"] .header-wrapper {
    background: rgba(20, 22, 24, 0.72);
    border-bottom-color: rgba(226, 227, 225, 0.06);
  }

  html:lang(en) .header-wrapper {
    background: rgba(249, 249, 247, 0.72);
  }

  /* === Nav Container — 3-zone flex layout === */
  .nav-inner {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    max-width: 1072px;
    margin-inline-start: auto;
    margin-inline-end: auto;
    padding: 0 1rem;
    line-height: 44px;
    gap: 0;
    min-height: 52px;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .nav-inner {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .nav-inner {
      padding: 0 2rem;
    }
  }

  @media (min-width: 1400px) {
    .nav-inner {
      max-width: 1320px;
    }
  }

  @media (min-width: 1600px) {
    .nav-inner {
      max-width: 1500px;
    }
  }

  @media (min-width: 1920px) {
    .nav-inner {
      max-width: 1760px;
    }
  }

  /* === Logo (left zone) === */
  .nav-logo {
    margin: auto 0 auto 0;
    flex-shrink: 0;
  }

  @media (min-width: 640px) {
    .nav-logo {
      margin-right: 12px;
    }
  }

  .nav-logo-link {
    font-family: var(--font-body, system-ui, sans-serif);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--foreground);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .nav-logo-link:hover {
    color: var(--accent);
  }

  /* === Nav Links (center zone) === */
  .nav-links {
    display: none;
    align-items: center;
    gap: 6px;
    flex: 1;
    min-width: 0;
    justify-content: center;
    list-style: none;
    padding: 0;
    white-space: nowrap;
    overflow-x: auto;
    word-break: keep-all;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  @media (min-width: 640px) {
    .nav-links {
      display: flex;
    }

    :global([data-nav-overflow="true"]) .nav-links {
      display: none;
    }

    :global([data-nav-overflow="true"]) .hamburger-menu {
      display: flex;
    }
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: var(--radius-md, 6px);
    background: transparent;
    color: var(--foreground-soft);
    font-family: var(--font-body, system-ui, sans-serif);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.01em;
    text-decoration: none;
    border: none;
    line-height: 1.4;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .nav-link:hover {
    background: rgba(30, 35, 30, 0.05);
    color: var(--foreground);
  }

  html[data-theme="dark"] .nav-link:hover {
    background: rgba(226, 227, 225, 0.06);
  }

  .nav-link--active {
    color: var(--foreground);
    font-weight: 500;
    background: rgba(30, 35, 30, 0.04);
  }

  html[data-theme="dark"] .nav-link--active {
    background: rgba(226, 227, 225, 0.05);
  }

  .nav-link-text {
    display: inline;
  }

  /* Hide scrollbar on nav-links horizontal scroll */
  .nav-links::-webkit-scrollbar {
    display: none;
  }

  /* === Widget Area (right zone) === */
  .nav-widgets {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    flex-wrap: nowrap;
    gap: 2px;
    margin: auto 0 auto 0;
  }

  @media (min-width: 640px) {
    .nav-widgets {
      margin-left: 12px;
    }
  }

  /* === Search Chip === */
  .nav-search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    height: 30px;
    padding: 0 9px;
    border-radius: var(--radius-md, 6px);
    border: 1px solid rgba(30, 35, 30, 0.1);
    background: rgba(30, 35, 30, 0.02);
    color: var(--foreground-soft);
    font-size: 12.5px;
    cursor: pointer;
    flex-shrink: 0;
    transition: background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }

  .nav-search-trigger:hover {
    background: rgba(30, 35, 30, 0.05);
    border-color: rgba(30, 35, 30, 0.15);
    color: var(--foreground);
  }

  html[data-theme="dark"] .nav-search-trigger {
    border-color: rgba(226, 227, 225, 0.1);
    background: rgba(226, 227, 225, 0.03);
  }

  html[data-theme="dark"] .nav-search-trigger:hover {
    background: rgba(226, 227, 225, 0.07);
    border-color: rgba(226, 227, 225, 0.18);
  }

  .nav-search-trigger__label {
    font-size: 13px;
    white-space: nowrap;
  }

  .nav-search-trigger__keys {
    display: inline-flex;
    gap: 4px;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .nav-search-trigger kbd {
