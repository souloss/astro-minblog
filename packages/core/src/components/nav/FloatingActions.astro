---
import IconArrowNarrowUp from "../../assets/icons/IconArrowNarrowUp.svg";
import { SITE } from "virtual:astro-minimax/config";
import { t } from "../../utils/i18n.js";

const lang = SITE.lang;
---

{/*
  FloatingActions now only contains the back-to-top button.
  All other widgets (theme toggle, reading mode, settings, AI chat)
  have been moved into the navbar (Header.astro).
*/}

<div
  class="fixed right-5 bottom-5 z-50 flex flex-col items-center gap-3"
  id="floating-actions"
  role="group"
  aria-label="Page actions"
>
  <button
    id="back-to-top-btn"
    class="fab-btn pointer-events-none relative size-12 rounded-2xl border border-border/50 
           bg-glass-bg opacity-0 shadow-lg backdrop-blur-md
           transition-all duration-300 ease-out
           hover:border-accent/30 hover:shadow-xl hover:shadow-shadow-elevated/20
           active:scale-95"
    aria-label={lang === 'zh' ? '返回顶部' : 'Back to Top'}
    title={lang === 'zh' ? '返回顶部' : 'Back to Top'}
  >
    <svg class="progress-ring absolute inset-0 size-12 -rotate-90" viewBox="0 0 48 48">
      <circle
        class="progress-ring-bg"
        cx="24"
        cy="24"
        r="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-opacity="0.15"
      />
      <circle
        id="progress-ring-circle"
        class="progress-ring-progress"
        cx="24"
        cy="24"
        r="20"
        fill="none"
        stroke="var(--accent)"
        stroke-width="2"
        stroke-linecap="round"
        stroke-dasharray="125.66"
        stroke-dashoffset="125.66"
        style="transition: stroke-dashoffset 0.1s ease-out"
      />
    </svg>
    <IconArrowNarrowUp class="text-foreground-soft relative z-10 mx-auto size-5 transition-colors duration-200 group-hover:text-accent" />
  </button>
</div>

<script>
  import { getGlobalEventManager } from "../../utils/performance";

  function initFloatingActions() {
    const manager = getGlobalEventManager();

    const backToTopBtn = document.getElementById("back-to-top-btn");
    if (!backToTopBtn) return;

    const progressCircle = document.getElementById("progress-ring-circle");
    const circumference = 2 * Math.PI * 20;

    const updateVisibility = () => {
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrollProgress = docHeight > 0 ? scrollTop / docHeight : 0;
      
      if (scrollTop > 300) {
        backToTopBtn.classList.remove("opacity-0", "pointer-events-none");
        backToTopBtn.classList.add("opacity-100");
      } else {
        backToTopBtn.classList.add("opacity-0", "pointer-events-none");
        backToTopBtn.classList.remove("opacity-100");
      }
      
      if (progressCircle) {
        const offset = circumference - (scrollProgress * circumference);
        progressCircle.style.strokeDashoffset = String(Math.max(0, offset));
      }
    };

    manager.add(backToTopBtn, "click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    manager.add(window, "scroll", updateVisibility, { passive: true });
    updateVisibility();
  }

  initFloatingActions();
  document.addEventListener("astro:after-swap", initFloatingActions);
</script>

<style>
  .bg-glass-bg {
    background: var(--glass-bg);
  }
</style>