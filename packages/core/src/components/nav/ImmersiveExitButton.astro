---
import { SITE } from "virtual:astro-minimax/config";

const lang = SITE.lang;
---

<button
  id="immersive-exit-btn"
  class="immersive-exit-btn"
  aria-label={lang === 'zh' ? '退出沉浸模式' : 'Exit immersive mode'}
  title={lang === 'zh' ? '退出沉浸模式 (Esc)' : 'Exit immersive mode (Esc)'}
>
  <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M18 6 6 18"></path>
    <path d="m6 6 12 12"></path>
  </svg>
</button>

<script>
  function initImmersiveExit() {
    const btn = document.getElementById('immersive-exit-btn');
    if (!btn) return;

    btn.addEventListener('click', () => {
      if (history.length > 1) {
        history.back();
      } else {
        const currentLang = window.location.pathname.startsWith("/zh") ? "zh" : "en";
        window.location.href = "/" + currentLang + "/";
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        e.preventDefault();
        if (history.length > 1) {
          history.back();
        } else {
          const currentLang = window.location.pathname.startsWith("/zh") ? "zh" : "en";
          window.location.href = "/" + currentLang + "/";
        }
      }
    });
  }

  initImmersiveExit();
  document.addEventListener('astro:after-swap', initImmersiveExit);
</script>
