---
import { SITE } from "virtual:astro-minimax/config";
import { t } from "../../utils/i18n";

const lang = SITE.lang;

const labels = {
  title: t("settings.title", lang),
  close: t("settings.close", lang),
  tabTheme: t("settings.tabTheme", lang),
  tabAppearance: t("settings.tabAppearance", lang),
  tabReading: t("settings.tabReading", lang),
  tabLayout: t("settings.tabLayout", lang),
  tabGeneral: t("settings.tabGeneral", lang),
  colorScheme: t("settings.colorScheme", lang),
  borderRadius: t("settings.borderRadius", lang),
  fontSize: t("settings.fontSize", lang),
  fontSizeDesc: t("settings.fontSizeDesc", lang),
  readingLineHeight: t("settings.readingLineHeight", lang),
  readingWidth: t("settings.readingWidth", lang),
  readingTheme: t("settings.readingTheme", lang),
  readingFontFamily: t("settings.readingFontFamily", lang),
  focusMode: t("settings.focusMode", lang),
  focusModeDesc: t("settings.focusModeDesc", lang),
  postsLayout: t("settings.postsLayout", lang),
  widgets: t("settings.widgets", lang),
  showBackToTop: t("settings.showBackToTop", lang),
  showThemeToggle: t("settings.showThemeToggle", lang),
  showReadingTime: t("settings.showReadingTime", lang),
  showStickyBackToTop: t("settings.showStickyBackToTop", lang),
  showStickyBackToTopDesc: t("settings.showStickyBackToTopDesc", lang),
  animations: t("settings.animations", lang),
  animationsDesc: t("settings.animationsDesc", lang),
  cardHover: t("settings.cardHover", lang),
  cardHoverDesc: t("settings.cardHoverDesc", lang),
  smoothScroll: t("settings.smoothScroll", lang),
  reset: t("settings.reset", lang),

  small: t("settings.small", lang),
  medium: t("settings.medium", lang),
  large: t("settings.large", lang),
  xl: t("settings.xl", lang),
  narrow: t("settings.narrow", lang),
  wide: t("settings.wide", lang),
  comfortable: t("settings.comfortable", lang),
  relaxed: t("settings.relaxed", lang),
  compact: t("settings.compact", lang),
  serif: t("settings.serif", lang),
  sans: t("settings.sans", lang),
  mono: t("settings.mono", lang),
  system: t("settings.system", lang),
  fontCode: t("settings.fontCode", lang),
  fontLxgw: t("settings.fontLxgw", lang),
  fontZcool: t("settings.fontZcool", lang),
  fontReadable: t("settings.fontReadable", lang),
  fontClassic: t("settings.fontClassic", lang),
  readingThemeDefault: t("settings.readingThemeDefault", lang),
  readingThemeEyecare: t("settings.readingThemeEyecare", lang),
  readingThemeParchment: t("settings.readingThemeParchment", lang),
  readingThemeNight: t("settings.readingThemeNight", lang),
  readingThemeOled: t("settings.readingThemeOled", lang),
  immersiveMode: t("settings.immersiveMode", lang),
  immersiveModeDesc: t("settings.immersiveModeDesc", lang),
  // 布局模式标签
  layoutCard: "卡片",
  layoutGrid: "网格",
  layoutList: "列表",
  layoutCardDesc: "标题优先，适合阅读",
  layoutGridDesc: "三列网格，快速浏览",
  layoutListDesc: "紧凑列表，适合归档",
  hue: t("settings.hue", lang),
  hueDesc: lang === 'zh' ? '调整主题色相' : 'Adjust theme hue',
};

const layoutModes = [
  { id: 'card', name: labels.layoutCard, icon: 'M4 6h16M4 10h16M4 14h10M4 18h16', desc: labels.layoutCardDesc },
  { id: 'grid', name: labels.layoutGrid, icon: 'M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z', desc: labels.layoutGridDesc },
  { id: 'list', name: labels.layoutList, icon: 'M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01', desc: labels.layoutListDesc },
];
---

<div id="settings-panel" class="fixed right-5 bottom-24 z-50 hidden" role="dialog" aria-modal="false" aria-labelledby="settings-panel-title" aria-describedby="settings-panel-status">
  <div class="settings-panel-inner w-[340px] max-w-[calc(100vw-2.5rem)] h-[520px] max-h-[calc(100vh-8rem)] flex flex-col overflow-hidden rounded-2xl border border-border/30 bg-surface/98 backdrop-blur-xl shadow-2xl">
    <!-- Header -->
    <div class="flex items-center justify-between border-b border-border/30 px-4 py-3 shrink-0">
      <h3 id="settings-panel-title" class="text-sm font-semibold text-foreground">{labels.title}</h3>
      <button id="settings-close-btn" class="rounded-lg p-1 text-muted transition-colors hover:bg-muted/50 hover:text-foreground" aria-label={labels.close}>
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Tabs -->
    <div class="flex border-b border-border/30 bg-muted/10 shrink-0 overflow-x-auto" role="tablist" aria-label={labels.title}>
      <button id="settings-tab-appearance" type="button" role="tab" aria-selected="true" aria-controls="tab-appearance" data-tab="appearance" class="settings-tab flex-1 px-3 py-2.5 text-xs font-medium text-accent border-b-2 border-accent transition-colors whitespace-nowrap">{labels.tabAppearance}</button>
      <button id="settings-tab-layout" type="button" role="tab" aria-selected="false" aria-controls="tab-layout" data-tab="layout" class="settings-tab flex-1 px-3 py-2.5 text-xs font-medium text-muted border-b-2 border-transparent hover:text-foreground-soft transition-colors whitespace-nowrap">{labels.tabLayout}</button>
      <button id="settings-tab-general" type="button" role="tab" aria-selected="false" aria-controls="tab-general" data-tab="general" class="settings-tab flex-1 px-3 py-2.5 text-xs font-medium text-muted border-b-2 border-transparent hover:text-foreground-soft transition-colors whitespace-nowrap">{labels.tabGeneral}</button>
    </div>

    <!-- Tab Content -->
    <div class="overflow-y-auto flex-1">
      <!-- Appearance Tab (merged from theme + appearance) -->
      <div id="tab-appearance" class="tab-content p-4 space-y-4" role="tabpanel" aria-labelledby="settings-tab-appearance" tabindex="0">
        <div>
          <p class="mb-2 text-xs font-medium text-foreground-soft">{labels.colorScheme}</p>
          <div class="grid grid-cols-8 gap-1.5" id="color-scheme-options"></div>
        </div>
        <div>
          <p class="mb-1 text-xs font-medium text-foreground-soft">{labels.hue}</p>
          <p class="mb-3 text-xs text-muted">{labels.hueDesc}</p>
          <div class="flex items-center gap-3">
            <input type="range" id="hue-slider" min="0" max="360" step="1" value="165"
              class="flex-1 h-2 rounded-full appearance-none cursor-pointer"
              style="background: linear-gradient(to right, oklch(0.7 0.14 0), oklch(0.7 0.14 60), oklch(0.7 0.14 120), oklch(0.7 0.14 180), oklch(0.7 0.14 240), oklch(0.7 0.14 300), oklch(0.7 0.14 360))" />
          </div>
          <div class="mt-2 flex justify-between">
            <span class="text-xs text-muted">0°</span>
            <span id="hue-value" class="text-xs font-medium text-accent">165°</span>
            <span class="text-xs text-muted">360°</span>
          </div>
        </div>
        <div>
          <p class="mb-2 text-xs font-medium text-foreground-soft">{labels.borderRadius}</p>
          <div class="flex gap-2" id="radius-options">
            <button data-radius="sm" data-radius-value="0.5rem" class="radius-btn flex flex-1 items-center justify-center rounded-lg border border-border/50 px-3 py-2 text-xs font-medium transition-all hover:border-accent/50">{labels.small}</button>
            <button data-radius="md" data-radius-value="0.75rem" class="radius-btn flex flex-1 items-center justify-center rounded-lg border border-border/50 px-3 py-2 text-xs font-medium transition-all hover:border-accent/50">{labels.medium}</button>
            <button data-radius="lg" data-radius-value="1rem" class="radius-btn flex flex-1 items-center justify-center rounded-lg border border-border/50 px-3 py-2 text-xs font-medium transition-all hover:border-accent/50">{labels.large}</button>
            <button data-radius="xl" data-radius-value="1.5rem" class="radius-btn flex flex-1 items-center justify-center rounded-lg border border-border/50 px-3 py-2 text-xs font-medium transition-all hover:border-accent/50">{labels.xl}</button>
          </div>
        </div>
        <div>
          <p class="mb-1 text-xs font-medium text-foreground-soft">{labels.readingFontFamily}</p>
          <div class="grid grid-cols-3 gap-2">
            <button data-font-family="serif" class="font-family-btn flex items-center justify-center rounded-lg border border-border/50 px-3 py-2 text-xs font-medium transition-all hover:border-accent/50">{labels.serif}</button>
            <button data-font-family="sans" class="font-family-btn flex items-center justify-center rounded-lg border border-border/50 px-3 py-2 text-xs font-medium transition-all hover:border-accent/50">{labels.sans}</button>
            <button data-font-family="mono" class="font-family-btn flex items-center justify-center rounded-lg border border-border/50 px-3 py-2 text-xs font-medium transition-all hover:border-accent/50">{labels.mono}</button>
            <button data-font-family="system" class="font-family-btn flex items-center justify-center rounded-lg border border-border/50 px-3 py-2 text-xs font-medium transition-all hover:border-accent/50">{labels.system}</button>
            <button data-font-family="code" class="font-family-btn flex items-center justify-center rounded-lg border border-border/50 px-3 py-2 text-xs font-medium transition-all hover:border-accent/50">{labels.fontCode}</button>
            <button data-font-family="lxgw" class="font-family-btn flex items-center justify-center rounded-lg border border-border/50 px-3 py-2 text-xs font-medium transition-all hover:border-accent/50">{labels.fontLxgw}</button>
            <button data-font-family="zcool" class="font-family-btn flex items-center justify-center rounded-lg border border-border/50 px-3 py-2 text-xs font-medium transition-all hover:border-accent/50">{labels.fontZcool}</button>
            <button data-font-family="readable" class="font-family-btn flex items-center justify-center rounded-lg border border-border/50 px-3 py-2 text-xs font-medium transition-all hover:border-accent/50">{labels.fontReadable}</button>
            <button data-font-family="classic" class="font-family-btn flex items-center justify-center rounded-lg border border-border/50 px-3 py-2 text-xs font-medium transition-all hover:border-accent/50">{labels.fontClassic}</button>
          </div>
        </div>
        <div>
          <p class="mb-1 text-xs font-medium text-foreground-soft">{labels.fontSize}</p>
          <p class="mb-3 text-xs text-muted">{labels.fontSizeDesc}</p>
          <div class="flex items-center gap-3">
            <span class="text-xs text-muted">A</span>
            <input type="range" id="font-size-slider" min="0.85" max="1.25" step="0.05" value="1" class="flex-1 h-2 rounded-full appearance-none cursor-pointer" style="background: linear-gradient(to right, var(--accent) 0%, var(--accent) 50%, var(--muted) 50%, var(--muted) 100%)" />
            <span class="text-base text-muted">A</span>
          </div>
          <div class="mt-2 flex justify-between">
            <span class="text-xs text-muted">85%</span>
            <span id="font-size-value" class="text-xs font-medium text-accent">100%</span>
            <span class="text-xs text-muted">125%</span>
          </div>
        </div>
      </div>

      <!-- Layout Tab -->
      <div id="tab-layout" class="tab-content hidden p-4 space-y-4" role="tabpanel" aria-labelledby="settings-tab-layout" tabindex="0">
        <div>
          <p class="mb-2 text-xs font-medium text-foreground-soft">{labels.postsLayout}</p>
          <div class="flex flex-wrap gap-2" id="layout-mode-options"></div>
        </div>
        <div>
          <p class="mb-2 text-xs font-medium text-foreground-soft">{labels.widgets}</p>
          <div class="space-y-2">
            <div class="flex items-center justify-between py-1">
              <span class="text-sm text-foreground-soft">{labels.showThemeToggle}</span>
              <button id="widget-theme-toggle" role="switch" aria-checked="true" class="toggle-btn relative h-5 w-9 rounded-full transition-colors duration-200" style="background-color: var(--accent)">
                <span class="toggle-knob absolute left-0.5 top-0.5 h-4 w-4 rounded-full bg-white shadow transition-transform duration-200" style="transform: translateX(16px)"></span>
              </button>
            </div>
            <div class="flex items-center justify-between py-1">
              <span class="text-sm text-foreground-soft">{labels.showBackToTop}</span>
              <button id="widget-backtotop-toggle" role="switch" aria-checked="true" class="toggle-btn relative h-5 w-9 rounded-full transition-colors duration-200" style="background-color: var(--accent)">
                <span class="toggle-knob absolute left-0.5 top-0.5 h-4 w-4 rounded-full bg-white shadow transition-transform duration-200" style="transform: translateX(16px)"></span>
              </button>
            </div>
            <div class="flex items-center justify-between py-1">
              <span class="text-sm text-foreground-soft">{labels.showReadingTime}</span>
              <button id="widget-readingtime-toggle" role="switch" aria-checked="true" class="toggle-btn relative h-5 w-9 rounded-full transition-colors duration-200" style="background-color: var(--accent)">
                <span class="toggle-knob absolute left-0.5 top-0.5 h-4 w-4 rounded-full bg-white shadow transition-transform duration-200" style="transform: translateX(16px)"></span>
              </button>
            </div>

          </div>
        </div>
      </div>

      <!-- General Tab -->
      <div id="tab-general" class="tab-content hidden p-4 space-y-3" role="tabpanel" aria-labelledby="settings-tab-general" tabindex="0">
        <div class="flex items-center justify-between py-1">
          <div>
            <p class="text-sm text-foreground-soft">{labels.animations}</p>
            <p class="text-xs text-muted">{labels.animationsDesc}</p>
          </div>
          <button id="animation-toggle" role="switch" aria-checked="true" class="toggle-btn relative h-5 w-9 rounded-full transition-colors duration-200" style="background-color: var(--accent)">
            <span class="toggle-knob absolute left-0.5 top-0.5 h-4 w-4 rounded-full bg-white shadow transition-transform duration-200" style="transform: translateX(16px)"></span>
          </button>
        </div>
        <div class="flex items-center justify-between py-1">
          <div>
            <p class="text-sm text-foreground-soft">{labels.cardHover}</p>
            <p class="text-xs text-muted">{labels.cardHoverDesc}</p>
          </div>
          <button id="card-hover-toggle" role="switch" aria-checked="true" class="toggle-btn relative h-5 w-9 rounded-full transition-colors duration-200" style="background-color: var(--accent)">
            <span class="toggle-knob absolute left-0.5 top-0.5 h-4 w-4 rounded-full bg-white shadow transition-transform duration-200" style="transform: translateX(16px)"></span>
          </button>
        </div>
        <div class="flex items-center justify-between py-1">
          <p class="text-sm text-foreground-soft">{labels.smoothScroll}</p>
          <button id="smooth-scroll-toggle" role="switch" aria-checked="true" class="toggle-btn relative h-5 w-9 rounded-full transition-colors duration-200" style="background-color: var(--accent)">
            <span class="toggle-knob absolute left-0.5 top-0.5 h-4 w-4 rounded-full bg-white shadow transition-transform duration-200" style="transform: translateX(16px)"></span>
          </button>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="border-t border-border/30 p-3 shrink-0">
      <button id="settings-reset-btn" class="w-full rounded-xl bg-muted/30 px-3 py-2 text-xs font-medium text-foreground-soft transition-all hover:bg-muted/50 hover:text-foreground">
        {labels.reset}
      </button>
    </div>
  </div>
</div>

<!-- Toast notification -->
<div id="settings-toast" class="fixed bottom-32 right-5 z-[60] hidden" role="status" aria-live="polite" aria-atomic="true">
  <div id="settings-panel-status" class="rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white shadow-lg">
  </div>
</div>

<script define:vars={{ labels, layoutModes }}>
  function getPreferencesClient() {
    return window.__astroMinimaxPreferences;
  }

  const radiusValues = { sm: '0.5rem', md: '0.75rem', lg: '1rem', xl: '1.5rem' };

  function getThemePresets() {
    return getPreferencesClient()?.themePresets ?? [];
  }

  function loadSettings() {
    const preferencesClient = getPreferencesClient();
    if (!preferencesClient) return null;
    return preferencesClient.loadSettings();
  }

  function saveSettings(s) {
    const preferencesClient = getPreferencesClient();
    if (!preferencesClient) return;
    preferencesClient.saveSettings(s);
  }

  // Apply color scheme by setting data-color-scheme attribute
  // Colors are defined in themes.css and applied automatically via CSS
  function applyColorScheme(schemeId) {
    const root = document.documentElement;
    root.setAttribute('data-color-scheme', schemeId);
  }

  const SCHEME_HUE_MAP = {
    teal: 165,
    ocean: 210,
    rose: 350,
    forest: 155,
    midnight: 270,
    sunset: 40,
    mono: 0,
    github: 210,
  };

  function applyHue(hue) {
    const root = document.documentElement;
    root.style.setProperty('--hue', String(hue));
    const isDark = root.getAttribute('data-theme') === 'dark';
    // Only set --accent; derived tokens (--accent-soft, --accent-gradient-*, --brand-secondary)
    // auto-adapt via color-mix() in themes.css
    if (isDark) {
      root.style.setProperty('--accent', `oklch(0.75 0.14 ${hue})`);
    } else {
      root.style.setProperty('--accent', `oklch(0.55 0.14 ${hue})`);
    }
  }

  function updateHueUI(hue) {
    const slider = document.getElementById('hue-slider');
    const valueEl = document.getElementById('hue-value');
    if (slider) slider.value = hue;
    if (valueEl) valueEl.textContent = `${hue}°`;
  }

  function applyLayoutMode(mode) {
    const root = document.documentElement;
    root.setAttribute('data-layout', mode);
    
    // 找到所有文章列表容器
    const containers = document.querySelectorAll('[data-posts-grid]');
    containers.forEach(container => {
      // 设置 data-layout 属性
      container.setAttribute('data-layout', mode);
    });
    
    // 直接触发布局渲染
    document.dispatchEvent(new CustomEvent('layout-change', { detail: { mode } }));
    
    // 确保渲染函数被调用
    if (window.__renderPostsLayout) {
      window.__renderPostsLayout(mode);
    }
  }

  function applyRadius(value) {
    const root = document.documentElement;
    root.style.setProperty('--card-radius', value);
    
    // 应用到所有使用圆角的元素
    const cards = document.querySelectorAll('.rounded-3xl, .rounded-2xl, .rounded-xl, [class*="rounded-"]');
    cards.forEach(card => {
      if (card.closest('#settings-panel')) return; // 不影响设置面板本身
      card.style.borderRadius = value;
    });
  }

  function applyFontSize(size) {
    document.documentElement.style.fontSize = `${size}rem`;
    document.documentElement.style.setProperty('--font-size-scale', size);
  }

  function applyAnimations(enabled) {
    const root = document.documentElement;
    if (enabled) {
      root.classList.remove('reduce-motion');
      document.body.classList.remove('reduce-motion');
    } else {
      root.classList.add('reduce-motion');
      document.body.classList.add('reduce-motion');
    }
  }

  function applyCardHover(enabled) {
    document.body.setAttribute('data-card-hover', String(enabled));
    const root = document.documentElement;
    if (enabled) {
      root.classList.remove('no-card-hover');
    } else {
      root.classList.add('no-card-hover');
    }
  }

  function applySmoothScroll(enabled) {
    document.documentElement.classList.toggle('scroll-smooth', enabled);
  }

  function applyWidgets(settings) {
    const themeToggleBtn = document.getElementById('theme-btn');
    const backToTopBtn = document.getElementById('back-to-top-btn');
    const readingTimeEls = document.querySelectorAll('.reading-time');
    
    if (themeToggleBtn) themeToggleBtn.style.display = settings.widgets.themeToggle ? '' : 'none';
    if (backToTopBtn) backToTopBtn.style.display = settings.widgets.backToTop ? '' : 'none';
    readingTimeEls.forEach(el => el.style.display = settings.widgets.readingTime ? '' : 'none');
  }

  function applyReadingSettings(reading) {
    const root = document.documentElement;
    
    const lineHeights = { compact: '1.6', comfortable: '1.8', relaxed: '2' };
    const widths = { narrow: '65ch', medium: '72ch', wide: '80ch' };
    const fonts = {
      serif: '"Noto Serif SC", "Source Han Serif SC", Georgia, serif',
      sans: '"Noto Sans SC", "Source Han Sans SC", -apple-system, sans-serif',
      mono: '"JetBrains Mono", "Fira Code", "IBM Plex Mono", monospace',
      system: 'ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif',
      code: '"JetBrains Mono", "Fira Code", "Cascadia Code", "Source Code Pro", monospace',
      lxgw: '"LXGW WenKai", "LXGW WenKai Mono", "Noto Serif SC", serif',
      zcool: '"ZCOOL KuaiLe", "ZCOOL XiaoWei", "Ma Shan Zheng", cursive',
      readable: '"Literata", "Source Serif Pro", "Noto Serif SC", Georgia, serif',
      classic: '"Noto Serif SC", "Source Han Serif SC", "Songti SC", SimSun, serif',
    };
    
    root.style.setProperty('--reading-line-height', lineHeights[reading.lineHeight] || '1.8');
    root.style.setProperty('--reading-width', widths[reading.contentWidth] || '72ch');
    root.style.setProperty('--reading-font-family', fonts[reading.fontFamily] || fonts.system);
    
    root.classList.toggle('focus-mode', reading.focusMode);
  }

  function applyReadingTheme(themeId) {
    const root = document.documentElement;
    const DARK_READING_THEMES = ['night', 'oled'];
    
    // Clear any inline styles that might override CSS
    root.style.removeProperty('--reading-bg');
    root.style.removeProperty('--reading-surface');
    root.style.removeProperty('--reading-fg');
    root.style.removeProperty('--reading-muted');
    
    // Set data attribute - CSS will automatically apply correct colors
    root.setAttribute('data-reading-theme', themeId);
    
    // Auto-switch system theme for dark reading themes (night, oled)
    // This ensures visual consistency: when user selects a dark reading theme,
    // the entire UI (header, settings panel, etc.) switches to dark mode
    const currentTheme = root.getAttribute('data-theme');
    const isDarkReadingTheme = DARK_READING_THEMES.includes(themeId);
    const wasDarkReadingTheme = DARK_READING_THEMES.includes(root.dataset.previousReadingTheme || '');
    const applyTheme = value => {
      if (window.theme?.setTheme) {
        window.theme.setTheme(value);
        window.theme.setPreference?.();
      }
    };
    
    if (isDarkReadingTheme && currentTheme !== 'dark') {
      // Save current theme before switching (for restoration later)
      root.dataset.themeBeforeDarkReading = currentTheme || 'light';
      applyTheme('dark');
    } else if (!isDarkReadingTheme && wasDarkReadingTheme) {
      // Restore previous theme when switching away from dark reading theme
      const previousTheme = root.dataset.themeBeforeDarkReading || 'light';
      if (currentTheme !== previousTheme) {
        applyTheme(previousTheme);
      }
      delete root.dataset.themeBeforeDarkReading;
    }
    
    // Remember current theme for next comparison
    root.dataset.previousReadingTheme = themeId;
  }

  function showToast(message) {
    const toast = document.getElementById('settings-toast');
    if (toast) {
      const content = toast.querySelector('#settings-panel-status');
      if (content) content.textContent = message;
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 2000);
    }
  }

  function updateSwitch(btn, checked) {
    btn.setAttribute('aria-checked', String(checked));
    const knob = btn.querySelector('.toggle-knob');
    if (knob) knob.style.transform = checked ? 'translateX(16px)' : 'translateX(0)';
    btn.style.backgroundColor = checked ? 'var(--accent)' : 'var(--muted)';
  }

  function updateColorSchemeUI(schemeId) {
    document.querySelectorAll('[data-color-scheme]').forEach(btn => {
      const isActive = btn.dataset.colorScheme === schemeId;
      btn.classList.toggle('border-accent', isActive);
      btn.classList.toggle('ring-2', isActive);
      btn.classList.toggle('ring-accent/30', isActive);
      btn.classList.toggle('border-border/50', !isActive);
      const icon = btn.querySelector('.check-icon');
      if (icon) icon.classList.toggle('opacity-0', !isActive);
    });
  }

  function updateLayoutModeUI(mode) {
    document.querySelectorAll('[data-layout-mode]').forEach(btn => {
      const isActive = btn.dataset.layoutMode === mode;
      btn.classList.toggle('border-accent', isActive);
      btn.classList.toggle('bg-accent/10', isActive);
      btn.classList.toggle('text-accent', isActive);
      btn.classList.toggle('border-border/50', !isActive);
    });
  }

  function updateRadiusUI(radius) {
    document.querySelectorAll('[data-radius]').forEach(btn => {
      const isActive = btn.dataset.radius === radius;
      btn.classList.toggle('border-accent', isActive);
      btn.classList.toggle('bg-accent/10', isActive);
      btn.classList.toggle('text-accent', isActive);
      btn.classList.toggle('border-border/50', !isActive);
    });
  }

  function updateFontSizeUI(size) {
    const slider = document.getElementById('font-size-slider');
    const valueEl = document.getElementById('font-size-value');
    if (slider) {
      slider.value = size;
      const percent = ((size - 0.85) / (1.25 - 0.85)) * 100;
      slider.style.background = `linear-gradient(to right, var(--accent) 0%, var(--accent) ${percent}%, var(--muted) ${percent}%, var(--muted) 100%)`;
    }
    if (valueEl) valueEl.textContent = `${Math.round(size * 100)}%`;
  }

  function switchTab(tabName) {
    document.querySelectorAll('.settings-tab').forEach(tab => {
      const isActive = tab.dataset.tab === tabName;
      tab.setAttribute('aria-selected', String(isActive));
      tab.setAttribute('tabindex', isActive ? '0' : '-1');
      tab.classList.toggle('text-accent', isActive);
      tab.classList.toggle('border-accent', isActive);
      tab.classList.toggle('text-muted', !isActive);
      tab.classList.toggle('border-transparent', !isActive);
    });
    document.querySelectorAll('.tab-content').forEach(content => {
      const isActive = content.id === `tab-${tabName}`;
      content.classList.toggle('hidden', !isActive);
      content.toggleAttribute('hidden', !isActive);
    });
  }

  function renderUI() {
    const colorContainer = document.getElementById('color-scheme-options');
    const layoutContainer = document.getElementById('layout-mode-options');
    const themePresets = getThemePresets();

    if (colorContainer) {
      colorContainer.innerHTML = themePresets.map(p => {
        // Generate gradient from accent colors
        const gradient = `linear-gradient(135deg, ${p.light.accent} 0%, ${p.dark.accent} 100%)`;
        return `
          <button data-color-scheme="${p.id}" 
                  class="group relative aspect-square rounded-lg border border-border/50 transition-all hover:border-accent/50 hover:scale-105" 
                  title="${p.name}">
            <div class="absolute inset-1 rounded-md" style="background: ${gradient}"></div>
            <div class="check-icon absolute inset-0 flex items-center justify-center opacity-0 transition-opacity">
              <svg class="size-3.5 text-white drop-shadow-lg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
          </button>
        `;
      }).join('');
    }

    if (layoutContainer) {
      layoutContainer.innerHTML = layoutModes.map(m => `
        <button data-layout-mode="${m.id}" class="layout-btn flex flex-col items-center gap-1.5 rounded-xl border border-border/50 p-3 transition-all hover:border-accent/50 hover:bg-accent/5">
          <svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="${m.icon}"></path></svg>
          <span class="text-xs font-medium whitespace-nowrap">${m.name}</span>
        </button>
      `).join('');
    }
  }

  const settingsPanelState = window.__settingsPanelState ?? {
    lastFocusedElement: null,
    listenersAttached: false,
  };
  window.__settingsPanelState = settingsPanelState;

  function getSettingsPanel() {
    return document.getElementById('settings-panel');
  }

  function closeSettingsPanel() {
    const panel = getSettingsPanel();
    if (!panel) return;
    panel.classList.add('hidden');
    panel.setAttribute('aria-hidden', 'true');
    settingsPanelState.lastFocusedElement?.focus?.();
  }

  function openSettingsPanel() {
    const panel = getSettingsPanel();
    if (!panel) return;
    settingsPanelState.lastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    panel.classList.remove('hidden');
    panel.setAttribute('aria-hidden', 'false');
    requestAnimationFrame(() => {
      const activeTab = panel.querySelector('.settings-tab[aria-selected="true"]');
      activeTab?.focus?.();
    });
  }

  function init() {
    const panel = document.getElementById('settings-panel');
    const closeBtn = document.getElementById('settings-close-btn');
    const resetBtn = document.getElementById('settings-reset-btn');
    const fontSizeSlider = document.getElementById('font-size-slider');
  
    if (!panel) return;

    panel.setAttribute('aria-hidden', panel.classList.contains('hidden') ? 'true' : 'false');

    const getFocusableElements = () => Array.from(panel.querySelectorAll(
      'button:not([disabled]), [href], input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'
    )).filter(el => !el.hasAttribute('hidden') && !el.classList.contains('hidden'));

    const handlePanelKeydown = (event) => {
      if (panel.classList.contains('hidden')) return;

      if (event.key === 'Escape') {
        event.preventDefault();
        closeSettingsPanel();
        return;
      }

      if (event.key === 'ArrowRight' || event.key === 'ArrowLeft') {
        const tabs = Array.from(panel.querySelectorAll('.settings-tab'));
        const currentIndex = tabs.findIndex(tab => tab.getAttribute('aria-selected') === 'true');
        if (currentIndex === -1) return;
        const direction = event.key === 'ArrowRight' ? 1 : -1;
        const nextIndex = (currentIndex + direction + tabs.length) % tabs.length;
        const nextTab = tabs[nextIndex];
        event.preventDefault();
        switchTab(nextTab.dataset.tab);
        nextTab.focus();
        return;
      }

      if (event.key === 'Tab') {
        const focusableElements = getFocusableElements();
        if (focusableElements.length === 0) return;
        const first = focusableElements[0];
        const last = focusableElements[focusableElements.length - 1];
        const activeElement = document.activeElement;

        if (event.shiftKey && activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      }
    };
    
    const animationToggle = document.getElementById('animation-toggle');
    const cardHoverToggle = document.getElementById('card-hover-toggle');
    const smoothScrollToggle = document.getElementById('smooth-scroll-toggle');
    const themeToggle = document.getElementById('widget-theme-toggle');
    const backToTopToggle = document.getElementById('widget-backtotop-toggle');
    const readingTimeToggle = document.getElementById('widget-readingtime-toggle');

    const preferencesClient = getPreferencesClient();
    if (!preferencesClient) {
      requestAnimationFrame(init);
      return;
    }

    const defaultSettings = preferencesClient.getInitialSettings();

    renderUI();
    const settings = loadSettings();
    if (!settings) return;

    // Apply all settings
      applyColorScheme(settings.theme.colorScheme);
      applyLayoutMode(settings.layout.postsLayout);
      applyRadius(radiusValues[settings.theme.radius] || '1rem');
      applyFontSize(settings.appearance.fontSize);
      applyAnimations(settings.animations.enabled);
      applyCardHover(settings.animations.cardHover);
      applySmoothScroll(settings.animations.smoothScroll);
      applyWidgets(settings);
      applyReadingSettings(settings.reading);
      applyReadingTheme(settings.reading.theme);
      applyHue(settings.theme.hue ?? 165);

    // Update UI
      updateColorSchemeUI(settings.theme.colorScheme);
      updateLayoutModeUI(settings.layout.postsLayout);
      updateRadiusUI(settings.theme.radius);
      updateFontSizeUI(settings.appearance.fontSize);
      updateHueUI(settings.theme.hue ?? 165);
      if (animationToggle) updateSwitch(animationToggle, settings.animations.enabled);
      if (cardHoverToggle) updateSwitch(cardHoverToggle, settings.animations.cardHover);
      if (smoothScrollToggle) updateSwitch(smoothScrollToggle, settings.animations.smoothScroll);
    if (themeToggle) updateSwitch(themeToggle, settings.widgets.themeToggle);
    if (backToTopToggle) updateSwitch(backToTopToggle, settings.widgets.backToTop);
    if (readingTimeToggle) updateSwitch(readingTimeToggle, settings.widgets.readingTime);

    // Reading settings UI (removed — now in immersive view)
    
    // Tab switching
    document.querySelectorAll('.settings-tab').forEach(tab => {
      if (tab.dataset.settingsTabBound === 'true') return;
      tab.addEventListener('click', () => switchTab(tab.dataset.tab));
      tab.dataset.settingsTabBound = 'true';
    });
    if (!settingsPanelState.listenersAttached) {
      panel.addEventListener('keydown', handlePanelKeydown);
      settingsPanelState.listenersAttached = true;
    }
    switchTab('appearance');

    // Color scheme handlers
    document.getElementById('color-scheme-options')?.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-color-scheme]');
      if (!btn) return;
      const schemeId = btn.dataset.colorScheme;
      const themePresets = getThemePresets();
      const preset = themePresets.find(p => p.id === schemeId);
      if (!preset) return;
      
      settings.theme.colorScheme = schemeId;
      const schemeHue = SCHEME_HUE_MAP[schemeId] ?? 165;
      settings.theme.hue = schemeHue;
      saveSettings(settings);
      applyColorScheme(schemeId);
      updateColorSchemeUI(schemeId);
      applyHue(schemeHue);
      updateHueUI(schemeHue);
    });

    // Layout mode handlers
    document.getElementById('layout-mode-options')?.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-layout-mode]');
      if (!btn) return;
      const mode = btn.dataset.layoutMode;
      
      settings.layout.postsLayout = mode;
      saveSettings(settings);
      applyLayoutMode(mode);
      updateLayoutModeUI(mode);
    });

    // Radius handlers
    document.getElementById('radius-options')?.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-radius]');
      if (!btn) return;
      const r = btn.dataset.radius;
      
      settings.theme.radius = r;
      saveSettings(settings);
      applyRadius(radiusValues[r]);
      updateRadiusUI(r);
    });

    // Reading theme handlers (removed — now in immersive view settings)

    // Font size handler
    fontSizeSlider?.addEventListener('input', (e) => {
      const size = parseFloat(e.target.value);
      settings.appearance.fontSize = size;
      saveSettings(settings);
      applyFontSize(size);
      updateFontSizeUI(size);
    });

    // Hue slider handler
    const hueSlider = document.getElementById('hue-slider');
    hueSlider?.addEventListener('input', (e) => {
      const hue = parseInt(e.target.value);
      settings.theme.hue = hue;
      saveSettings(settings);
      applyHue(hue);
      updateHueUI(hue);
    });

    // Toggle handlers
    animationToggle?.addEventListener('click', () => {
      settings.animations.enabled = !settings.animations.enabled;
      saveSettings(settings);
      applyAnimations(settings.animations.enabled);
      updateSwitch(animationToggle, settings.animations.enabled);
    });

    cardHoverToggle?.addEventListener('click', () => {
      settings.animations.cardHover = !settings.animations.cardHover;
      saveSettings(settings);
      applyCardHover(settings.animations.cardHover);
      updateSwitch(cardHoverToggle, settings.animations.cardHover);
    });

    smoothScrollToggle?.addEventListener('click', () => {
      settings.animations.smoothScroll = !settings.animations.smoothScroll;
      saveSettings(settings);
      applySmoothScroll(settings.animations.smoothScroll);
      updateSwitch(smoothScrollToggle, settings.animations.smoothScroll);
    });

    themeToggle?.addEventListener('click', () => {
      settings.widgets.themeToggle = !settings.widgets.themeToggle;
      saveSettings(settings);
      applyWidgets(settings);
      updateSwitch(themeToggle, settings.widgets.themeToggle);
    });

    backToTopToggle?.addEventListener('click', () => {
      settings.widgets.backToTop = !settings.widgets.backToTop;
      saveSettings(settings);
      applyWidgets(settings);
      updateSwitch(backToTopToggle, settings.widgets.backToTop);
    });

    readingTimeToggle?.addEventListener('click', () => {
      settings.widgets.readingTime = !settings.widgets.readingTime;
      saveSettings(settings);
      applyWidgets(settings);
      updateSwitch(readingTimeToggle, settings.widgets.readingTime);
    });

    // Reset handler
    resetBtn?.addEventListener('click', () => {
      const resetState = preferencesClient.resetSettings();
      Object.assign(settings, resetState);
      saveSettings(settings);
      
      applyColorScheme(settings.theme.colorScheme);
      applyLayoutMode(settings.layout.postsLayout);
      applyRadius(radiusValues[settings.theme.radius]);
      applyFontSize(settings.appearance.fontSize);
      applyAnimations(settings.animations.enabled);
      applyCardHover(settings.animations.cardHover);
      applySmoothScroll(settings.animations.smoothScroll);
      applyWidgets(settings);
      applyReadingSettings(settings.reading);
      applyReadingTheme(settings.reading.theme);
      applyHue(settings.theme.hue ?? 165);

      updateColorSchemeUI(settings.theme.colorScheme);
      updateLayoutModeUI(settings.layout.postsLayout);
      updateRadiusUI(settings.theme.radius);
      updateFontSizeUI(settings.appearance.fontSize);
      updateHueUI(settings.theme.hue ?? 165);
      if (animationToggle) updateSwitch(animationToggle, settings.animations.enabled);
      if (cardHoverToggle) updateSwitch(cardHoverToggle, settings.animations.cardHover);
      if (smoothScrollToggle) updateSwitch(smoothScrollToggle, settings.animations.smoothScroll);
    if (themeToggle) updateSwitch(themeToggle, settings.widgets.themeToggle);
    if (backToTopToggle) updateSwitch(backToTopToggle, settings.widgets.backToTop);
    if (readingTimeToggle) updateSwitch(readingTimeToggle, settings.widgets.readingTime);
    });

    if (closeBtn && closeBtn.dataset.settingsCloseBound !== 'true') {
      closeBtn.addEventListener('click', closeSettingsPanel);
      closeBtn.dataset.settingsCloseBound = 'true';
    }
    
    // Listen for theme mode changes (light/dark) and re-apply color scheme
    window.addEventListener('themechange', () => {
      updateColorSchemeUI(settings.theme.colorScheme);
      applyHue(settings.theme.hue ?? 165);
    });
  }

  window.__settingsPanel = {
    toggle: () => {
      const panel = document.getElementById('settings-panel');
      if (panel) {
        if (panel.classList.contains('hidden')) {
          openSettingsPanel();
        } else {
          closeSettingsPanel();
        }
      }
    },
    getSettings: loadSettings,
    applyColorScheme: applyColorScheme,
    applyLayoutMode: applyLayoutMode,
    applyReadingSettings: applyReadingSettings,
    applyReadingTheme: applyReadingTheme,
  };

  init();
  document.addEventListener('astro:after-swap', init);
</script>

<style>
  input[type="range"]::-webkit-slider-thumb {
    appearance: none;
    width: 14px;
    height: 14px;
    border-radius: var(--radius-full);
    background: var(--accent);
    cursor: pointer;
    border: 2px solid white;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  }
  
  input[type="range"]::-moz-range-thumb {
    width: 14px;
    height: 14px;
    border-radius: var(--radius-full);
    background: var(--accent);
    cursor: pointer;
    border: 2px solid white;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  }
</style>
