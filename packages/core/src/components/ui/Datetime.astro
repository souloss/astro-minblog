---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import IconCalendar from "../../assets/icons/IconCalendar.svg";
import { SITE } from "virtual:astro-minimax/config";
import { t } from "../../utils/i18n";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = {
  class?: string;
  size?: "sm" | "lg";
  pubDatetime: string | Date;
  timezone?: string;
  modDatetime?: string | Date | null;
  lang?: string;
};

const {
  pubDatetime,
  modDatetime,
  size = "sm",
  class: className = "",
  timezone: postTimezone,
  lang,
} = Astro.props;

const currentLang = lang ?? SITE.lang;
const isModified = modDatetime && modDatetime > pubDatetime;

const pubDate = dayjs(pubDatetime).tz(postTimezone || SITE.timezone);
const modDate = modDatetime ? dayjs(modDatetime).tz(postTimezone || SITE.timezone) : null;

const dateDisplay =
  currentLang === "zh"
    ? pubDate.format("YYYY 年 M 月 D 日")
    : pubDate.format("D MMM, YYYY");

const modDateDisplay = modDate
  ? currentLang === "zh"
    ? modDate.format("YYYY 年 M 月 D 日")
    : modDate.format("D MMM, YYYY")
  : "";
---

<div class:list={["flex items-center gap-x-2", className]}>
  <IconCalendar
    class:list={[
      "inline-block size-6 min-w-5.5",
      { "scale-90": size === "sm" },
    ]}
  />
  <time
    class:list={["text-sm", { "sm:text-base": size === "lg" }]}
    datetime={pubDate.toISOString()}>{dateDisplay}</time
  >
  {isModified && (
    <span
      class="updated-dot relative inline-flex items-center justify-center size-2 cursor-help"
      title={t("post.updatedTooltip", currentLang).replace("{date}", modDateDisplay)}
    >
      <span class="absolute inset-0 rounded-full bg-accent animate-pulse-dot"></span>
      <span class="absolute inset-0 rounded-full bg-accent/30 animate-glow-dot"></span>
    </span>
  )}
</div>

<style>
  .updated-dot {
    margin-left: 4px;
  }
  
  /* 优雅的呼吸灯效果：仅在可见时脉冲一次，然后保持静态 */
  @keyframes pulse-once {
    0% {
      transform: scale(1);
      opacity: 0.8;
    }
    50% {
      transform: scale(1.3);
      opacity: 1;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }
  
  /* 外层光晕：缓慢扩散消失 */
  @keyframes glow-pulse {
    0% {
      transform: scale(1);
      opacity: 0.5;
    }
    70% {
      transform: scale(2);
      opacity: 0;
    }
    100% {
      transform: scale(1);
      opacity: 0;
    }
  }
  
  .animate-pulse-dot {
    animation: pulse-once 1.5s ease-out;
    animation-delay: 0.3s;
  }
  
  .animate-glow-dot {
    animation: glow-pulse 2.5s ease-out infinite;
    animation-delay: 1s;
  }
</style>
