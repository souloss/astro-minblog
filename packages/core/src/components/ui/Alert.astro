---
/**
 * GitHub-style Alert component for MDX
 * Supports WCAG AA accessibility with proper ARIA attributes
 */
interface Props {
  type: "note" | "tip" | "important" | "warning" | "caution";
  title?: string;
}

const { type, title } = Astro.props;

const defaultTitles: Record<string, string> = {
  note: "Note",
  tip: "Tip",
  important: "Important",
  warning: "Warning",
  caution: "Caution",
};

const displayTitle = title || defaultTitles[type] || "Note";

// Warning and caution are more urgent, use role="alert"
// Others use role="status" for less urgent announcements
const isUrgent = type === "warning" || type === "caution";
---

<div 
  class:list={["markdown-alert", `markdown-alert-${type}`]}
  role={isUrgent ? "alert" : "status"}
  aria-live={isUrgent ? "assertive" : "polite"}
>
  <p class="markdown-alert-title">
    {displayTitle}
  </p>
  <slot />
</div>
