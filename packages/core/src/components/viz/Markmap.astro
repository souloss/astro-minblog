---
/**
 * Markmap component for direct use in Astro templates.
 *
 * IMPORTANT: For markdown code blocks, use ```markmap syntax directly.
 * The remark-markmap plugin will automatically transform it.
 *
 * This component is for programmatic use in .astro files.
 */

import { randomUUID } from "node:crypto";
import { Transformer } from "markmap-lib";
import VizContainer from "./VizContainer.astro";

interface Props {
  /** Markdown content for the mindmap */
  content: string;
  /** Optional ID for the wrapper element */
  id?: string;
  /** Markmap options (colorFreezeLevel, etc.) */
  options?: Record<string, unknown>;
}

const { content, id, options = {} } = Astro.props;
const uniqueId = id || `markmap-${randomUUID()}`;

// Transform markdown to mindmap tree structure
const transformer = new Transformer();
const { root } = transformer.transform(content);
---

<VizContainer minHeight="300px">
  <div class="markmap-wrap" id={uniqueId} data-viz-type="markmap" data-source={content}>
    <script is:inline type="application/json" set:html={JSON.stringify(root)} />
    <script is:inline type="application/json" set:html={JSON.stringify(options)} />
  </div>
</VizContainer>

<style is:global>
  .markmap-wrap {
    position: relative;
    height: max-content;
    width: 100%;
    min-height: 300px;
  }

  .markmap-wrap > svg {
    width: 100%;
    height: auto;
    margin: 0;
    padding: 0;
  }

  .mm-toolbar {
    position: absolute;
    right: 0.5em;
    bottom: 0.5em;
  }

  :global(html.markmap-dark) .markmap {
    --markmap-text-color: var(--foreground);
    --markmap-code-bg: var(--muted);
    --markmap-circle-open-bg: var(--card);
  }
</style>