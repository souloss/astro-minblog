---
/**
 * Script-only component that ensures the Mermaid rendering script is loaded.
 * Include in PostDetails when the post body contains ```mermaid code blocks.
 * The script handles pre.mermaid elements created by remark-mermaid-codeblock.
 * 
 * Features:
 * - Zoom in/out/reset controls
 * - Pan (Shift+drag or middle mouse button)
 * - Fullscreen mode
 * - Hover-to-show toolbar
 * - Code/preview toggle (optional)
 */
---

<script>
  import mermaid from "mermaid";
  import { getGlobalEventManager } from "../../utils/performance";

  // Viz container initialization code (inlined to prevent tree-shaking)
  const trackedListeners: Array<{
    target: EventTarget;
    type: string;
    handler: EventListenerOrEventListenerObject;
    options?: AddEventListenerOptions | boolean;
  }> = [];

  function addTrackedListener(
    target: EventTarget,
    type: string,
    handler: EventListenerOrEventListenerObject,
    options?: AddEventListenerOptions | boolean
  ) {
    target.addEventListener(type, handler, options);
    trackedListeners.push({ target, type, handler, options });
  }

  function cleanupListeners() {
    for (const { target, type, handler, options } of trackedListeners) {
      target.removeEventListener(type, handler, options);
    }
    trackedListeners.length = 0;
  }

  function initVizContainers() {
    document.querySelectorAll<HTMLElement>(".viz-container").forEach(container => {
      if (container.dataset.vizCtrlInit === "initialized") return;
      
      const viewport = container.querySelector<HTMLElement>(".viz-viewport");
      if (!viewport) return;

      container.dataset.vizCtrlInit = "initialized";

      let scale = 1;
      let translateX = 0;
      let translateY = 0;
      const MIN_SCALE = 0.3;
      const MAX_SCALE = 5;
      const ZOOM_STEP = 0.2;

      function applyTransform() {
        viewport!.style.transform = `scale(${scale}) translate(${translateX}px, ${translateY}px)`;
      }

      const zoomInBtn = container.querySelector(".viz-zoom-in");
      if (zoomInBtn) {
        addTrackedListener(zoomInBtn, "click", (e: Event) => {
          e.preventDefault();
          e.stopPropagation();
          scale = Math.min(MAX_SCALE, scale + ZOOM_STEP);
          applyTransform();
        });
      }

      const zoomOutBtn = container.querySelector(".viz-zoom-out");
      if (zoomOutBtn) {
        addTrackedListener(zoomOutBtn, "click", (e: Event) => {
          e.preventDefault();
          e.stopPropagation();
          scale = Math.max(MIN_SCALE, scale - ZOOM_STEP);
          applyTransform();
        });
      }

      const resetBtn = container.querySelector(".viz-reset");
      if (resetBtn) {
        addTrackedListener(resetBtn, "click", (e: Event) => {
          e.preventDefault();
          e.stopPropagation();
          scale = 1;
          translateX = 0;
          translateY = 0;
          applyTransform();
        });
      }

      if (container.dataset.vizZoom === "true") {
        addTrackedListener(container, "wheel", (e: Event) => {
          const wheelEvent = e as WheelEvent;
          const isZoomIntent = wheelEvent.ctrlKey || wheelEvent.metaKey || wheelEvent.deltaMode === 0;
          if (!isZoomIntent) return;
          e.preventDefault();
          e.stopPropagation();
          const delta = wheelEvent.deltaY > 0 ? -ZOOM_STEP : ZOOM_STEP;
          scale = Math.max(MIN_SCALE, Math.min(MAX_SCALE, scale + delta));
          applyTransform();
        }, { passive: false });

        let isPanning = false;
        let startX = 0;
        let startY = 0;

        addTrackedListener(container, "mousedown", (e: Event) => {
          const mouseEvent = e as MouseEvent;
          if (!mouseEvent.shiftKey && mouseEvent.button !== 1) return;
          e.preventDefault();
          isPanning = true;
          startX = mouseEvent.clientX;
          startY = mouseEvent.clientY;
          container.style.cursor = "grabbing";
        });

        addTrackedListener(window, "mousemove", (e: Event) => {
          if (!isPanning) return;
          const mouseEvent = e as MouseEvent;
          translateX += (mouseEvent.clientX - startX) / scale;
          translateY += (mouseEvent.clientY - startY) / scale;
          startX = mouseEvent.clientX;
          startY = mouseEvent.clientY;
          applyTransform();
        });

        addTrackedListener(window, "mouseup", () => {
          if (!isPanning) return;
          isPanning = false;
          container.style.cursor = "";
        });
      }

      const fsBtn = container.querySelector<HTMLElement>(".viz-fullscreen");
      if (fsBtn && container.dataset.vizFullscreen === "true") {
        const enterIcon = fsBtn.querySelector(".viz-fs-enter");
        const exitIcon = fsBtn.querySelector(".viz-fs-exit");

        addTrackedListener(fsBtn, "click", (e: Event) => {
          e.preventDefault();
          e.stopPropagation();
          if (document.fullscreenElement === container) {
            document.exitFullscreen().catch(() => {});
          } else {
            container.requestFullscreen().catch(() => {});
          }
        });

        const handleFullscreenChange = () => {
          const isFs = document.fullscreenElement === container;
          if (isFs) {
            enterIcon?.classList.add("hidden");
            exitIcon?.classList.remove("hidden");
            container.style.background = "var(--background)";
            container.classList.add("p-4");
          } else {
            enterIcon?.classList.remove("hidden");
            exitIcon?.classList.add("hidden");
            container.style.background = "";
            container.classList.remove("p-4");
          }
        };

        // fullscreenchange 事件应该绑定到 document 而不是 container
        addTrackedListener(document, "fullscreenchange", handleFullscreenChange);
      }
    });
  }

  const manager = getGlobalEventManager();
  manager.onCleanup(cleanupListeners);

  document.addEventListener("astro:page-load", initVizContainers);
  window.addEventListener("viz:init", initVizContainers);

  function getIsDark(): boolean {
    return document.documentElement.getAttribute("data-theme") === "dark";
  }

  // Helper to get CSS variable value with fallback
  function getCSSVar(name: string, fallback: string): string {
    const value = getComputedStyle(document.documentElement)
      .getPropertyValue(name)
      .trim();
    return value || fallback;
  }

  function getMermaidConfig(isDark: boolean) {
    const base = {
      fontSize: "14px",
      fontFamily: '"Inter", "Segoe UI", system-ui, sans-serif',
    };

    // Get colors from CSS variables for theme consistency
    const foreground = getCSSVar('--foreground', isDark ? '#f5f5f7' : '#1d1d1f');
    const foregroundSoft = getCSSVar('--foreground-soft', isDark ? '#a1a1a6' : '#6e6e73');
    const muted = getCSSVar('--muted', isDark ? '#6e6e73' : '#86868b');
    const accent = getCSSVar('--accent', isDark ? '#4fd1c5' : '#0a9396');
    const card = getCSSVar('--card', isDark ? 'rgba(44, 44, 46, 0.6)' : 'rgba(255, 255, 255, 0.65)');
    const surface = getCSSVar('--surface', isDark ? 'rgba(28, 28, 30, 0.78)' : 'rgba(255, 255, 255, 0.72)');

    return {
      ...base,
      primaryColor: surface,
      primaryTextColor: foreground,
      primaryBorderColor: accent,
      lineColor: muted,
      background: "transparent",
      nodeBkg: surface,
      nodeBorder: accent,
      nodeTextColor: foreground,
      clusterBkg: card,
      clusterBorder: accent,
      edgeLabelBackground: surface,
      actorBorder: accent,
      actorBkg: surface,
      actorTextColor: foreground,
      actorLineColor: muted,
      signalColor: muted,
      signalTextColor: foreground,
      sequenceNumberColor: foreground,
      noteBkg: card,
      noteBorder: accent,
      noteTextColor: foreground,
    };
  }

  let renderCounter = 0;
  let isInitialized = false;
  let currentTheme: boolean | null = null;

  function initMermaid(isDark: boolean) {
    if (isInitialized && currentTheme === isDark) return;
    isInitialized = true;
    currentTheme = isDark;
    mermaid.initialize({
      startOnLoad: false,
      securityLevel: "loose",
      theme: "base" as const,
      themeVariables: getMermaidConfig(isDark),
    });
  }

  async function renderDiagram(wrapper: HTMLElement, isDark: boolean) {
    const id = wrapper.getAttribute("data-mermaid-id");
    const codeScript = wrapper.querySelector("script.mermaid-code");
    const output = wrapper.querySelector<HTMLElement>(`.mermaid-output`);

    if (!output || !codeScript) return;

    const code = JSON.parse(codeScript.textContent || '""');
    if (!code) return;

    try {
      renderCounter++;
      const svgId = `${id}-svg-${renderCounter}`;
      const { svg } = await mermaid.render(svgId, code);
      output.innerHTML = svg;
      
      // Trigger viz:init to bind controls for dynamically created containers
      window.dispatchEvent(new CustomEvent("viz:init"));
    } catch (error) {
      output.innerHTML = `<p class="mermaid-error">Render error: ${error instanceof Error ? error.message : "unknown"}</p>`;
    }
  }

  /**
   * Create toolbar buttons HTML
   */
  function createToolbarHTML(): string {
    return `
      <div class="viz-controls absolute right-2 bottom-2 z-10 flex items-center gap-1 rounded-lg border border-[var(--viz-border)] bg-[var(--viz-btn-bg)] p-1 opacity-0 shadow-sm backdrop-blur-sm transition-opacity duration-200 group-hover:opacity-100 focus-within:opacity-100">
        <button
          class="viz-btn viz-zoom-in flex size-7 items-center justify-center rounded-md text-foreground-soft transition-colors hover:bg-[var(--viz-btn-hover)] hover:text-accent"
          aria-label="Zoom in"
          title="Zoom in"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" />
          </svg>
        </button>
        <button
          class="viz-btn viz-zoom-out flex size-7 items-center justify-center rounded-md text-foreground-soft transition-colors hover:bg-[var(--viz-btn-hover)] hover:text-accent"
          aria-label="Zoom out"
          title="Zoom out"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
          </svg>
        </button>
        <button
          class="viz-btn viz-reset flex size-7 items-center justify-center rounded-md text-foreground-soft transition-colors hover:bg-[var(--viz-btn-hover)] hover:text-accent"
          aria-label="Reset view"
          title="Reset view"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" /><path d="M3 3v5h5" />
          </svg>
        </button>
        <div class="mx-0.5 h-4 w-px bg-[var(--viz-border)]"></div>
        <button
          class="viz-btn viz-fullscreen flex size-7 items-center justify-center rounded-md text-foreground-soft transition-colors hover:bg-[var(--viz-btn-hover)] hover:text-accent"
          aria-label="Toggle fullscreen"
          title="Toggle fullscreen"
        >
          <svg class="viz-fs-enter size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 3H5a2 2 0 0 0-2 2v3" /><path d="M21 8V5a2 2 0 0 0-2-2h-3" />
            <path d="M3 16v3a2 2 0 0 0 2 2h3" /><path d="M16 21h3a2 2 0 0 0 2-2v-3" />
          </svg>
          <svg class="viz-fs-exit hidden size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 3v3a2 2 0 0 1-2 2H3" /><path d="M21 8h-3a2 2 0 0 1-2-2V3" />
            <path d="M3 16h3a2 2 0 0 1 2 2v3" /><path d="M16 21v-3a2 2 0 0 1 2-2h3" />
          </svg>
        </button>
        <button
          class="viz-btn viz-toggle-code flex size-7 items-center justify-center rounded-md text-foreground-soft transition-colors hover:bg-[var(--viz-btn-hover)] hover:text-accent"
          aria-label="Toggle code view"
          title="View code"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />
          </svg>
        </button>
      </div>
    `;
  }

  async function renderPreBlock(pre: HTMLElement, isDark: boolean) {
    const code = pre.textContent || "";
    const uniqueId = `mermaid-pre-${Math.random().toString(36).slice(2, 11)}`;

    // Create VizContainer-like structure with full controls
    const container = document.createElement("div");
    container.className = "viz-container group relative my-6 overflow-hidden rounded-lg border";
    container.style.minHeight = "120px";
    container.setAttribute("data-viz-zoom", "true");
    container.setAttribute("data-viz-fullscreen", "true");
    container.setAttribute("data-mermaid-id", uniqueId);
    container.setAttribute("data-viz-type", "mermaid");

    // Create viewport for zoom/pan
    const viewport = document.createElement("div");
    viewport.className = "viz-viewport w-full origin-center";
    viewport.style.transform = "scale(1) translate(0px, 0px)";

    // Create wrapper for mermaid output
    const wrapper = document.createElement("div");
    wrapper.className = "mermaid-wrapper";
    wrapper.setAttribute("data-mermaid-id", uniqueId);
    wrapper.setAttribute("data-viz-type", "mermaid");

    // Create output container
    const output = document.createElement("div");
    output.className = "mermaid-output";
    output.id = `${uniqueId}-output`;

    // Create placeholder while loading
    const placeholder = document.createElement("div");
    placeholder.className = "mermaid-placeholder";
    placeholder.innerHTML = `
      <svg class="size-8 animate-pulse text-foreground-soft/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 3h18v18H3z" stroke-dasharray="4 2" /><path d="M9 3v18M15 3v18M3 9h18M3 15h18" stroke-dasharray="2 2" opacity="0.5" />
      </svg>
    `;

    // Create code storage
    const codeScript = document.createElement("script");
    codeScript.type = "application/json";
    codeScript.className = "mermaid-code";
    codeScript.textContent = JSON.stringify(code);

    // Create code view panel (hidden by default)
    const codeView = document.createElement("div");
    codeView.className = "mermaid-code-view hidden p-4 overflow-auto max-h-[60vh]";
    codeView.innerHTML = `<pre class="text-sm"><code class="language-mermaid">${escapeHtml(code)}</code></pre>`;

    // Assemble the structure
    output.appendChild(placeholder);
    wrapper.appendChild(output);
    viewport.appendChild(wrapper);
    container.appendChild(viewport);
    container.appendChild(codeScript);
    container.appendChild(codeView);
    
    // Add toolbar using innerHTML for cleaner code - CRITICAL: Add to container BEFORE replacing in DOM
    const toolbarContainer = document.createElement("div");
    toolbarContainer.innerHTML = createToolbarHTML();
    container.appendChild(toolbarContainer.firstElementChild!);

    // Replace pre with container - This adds to DOM
    pre.parentNode?.replaceChild(container, pre);

    // Use requestAnimationFrame to ensure DOM is ready before initializing controls
    requestAnimationFrame(() => {
      try {
        renderCounter++;
        const svgId = `${uniqueId}-svg-${renderCounter}`;
        mermaid.render(svgId, code).then(({ svg }) => {
          output.innerHTML = svg;
          
          // Setup code toggle button first
          setupCodeToggle(container, output, codeView);
          
          // Initialize viz controls for the new container with a small delay
          // to ensure DOM mutation is complete
          Promise.resolve().then(() => {
            window.dispatchEvent(new CustomEvent("viz:init"));
          });
        }).catch((error: Error) => {
          output.innerHTML = `<p class="mermaid-error">Render error: ${error?.message || "unknown"}</p>`;
        });
      } catch (error) {
        output.innerHTML = `<p class="mermaid-error">Render error: ${error instanceof Error ? error.message : "unknown"}</p>`;
      }
    });
  }

  /**
   * Setup code/preview toggle functionality
   */
  function setupCodeToggle(
    container: HTMLElement,
    output: HTMLElement,
    codeView: HTMLElement
  ) {
    const toggleBtn = container.querySelector(".viz-toggle-code");
    let showingCode = false;

    toggleBtn?.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      
      showingCode = !showingCode;
      
      if (showingCode) {
        output.classList.add("hidden");
        codeView.classList.remove("hidden");
        (toggleBtn as HTMLElement).title = "View diagram";
      } else {
        output.classList.remove("hidden");
        codeView.classList.add("hidden");
        (toggleBtn as HTMLElement).title = "View code";
      }
    });
  }

  /**
   * Escape HTML for code display
   */
  function escapeHtml(text: string): string {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  async function renderAllVisible() {
    const isDark = getIsDark();
    initMermaid(isDark);

    const observer = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;

          const el = entry.target as HTMLElement;
          obs.unobserve(el);

          if (el.matches("pre.mermaid")) {
            renderPreBlock(el, isDark);
          } else if (el.matches(".viz-container[data-mermaid-id]")) {
            renderDiagram(el, isDark);
          }
        }
      },
      { rootMargin: "200px" }
    );

    // Observe existing mermaid wrappers (from Mermaid.astro component)
    document.querySelectorAll<HTMLElement>(".viz-container[data-mermaid-id]").forEach(container => {
      const output = container.querySelector(".mermaid-output");
      const hasContent = output && output.querySelector("svg");
      if (!hasContent) observer.observe(container);
    });

    // Observe pre.mermaid blocks (from markdown code blocks)
    document.querySelectorAll<HTMLElement>("pre.mermaid").forEach(pre => {
      observer.observe(pre);
    });
  }

  async function reRenderAll() {
    const isDark = getIsDark();
    initMermaid(isDark);

    const containers = document.querySelectorAll<HTMLElement>(".viz-container[data-mermaid-id]");
    for (const container of containers) {
      await renderDiagram(container, isDark);
    }
  }

  window.addEventListener("themechange", () => {
    if ("requestIdleCallback" in window) {
      requestIdleCallback(() => reRenderAll(), { timeout: 300 });
    } else {
      setTimeout(() => reRenderAll(), 100);
    }
  });

  function init() {
    renderAllVisible();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }

  document.addEventListener("astro:page-load", init);
</script>

<style is:global>
  /* Mermaid container styles */
  .viz-container[data-mermaid-id] {
    background: var(--viz-bg);
    border-color: var(--viz-border);
    transition:
      background-color 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      border-color 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .viz-container[data-mermaid-id]:fullscreen {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  .viz-container[data-mermaid-id]:fullscreen .viz-viewport {
    position: absolute;
    inset: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .viz-container[data-mermaid-id]:fullscreen .viz-viewport > * {
    flex: 1;
    min-height: 0;
    min-width: 0;
  }

  .viz-container[data-mermaid-id]:fullscreen .viz-controls {
    opacity: 1 !important;
    pointer-events: auto;
  }

  /* Hover behavior for controls - using pure CSS for reliability */
  .viz-container[data-mermaid-id] .viz-controls {
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .viz-container[data-mermaid-id]:hover .viz-controls,
  .viz-container[data-mermaid-id] .viz-controls:focus-within {
    opacity: 1;
  }

  /* Touch devices - always show controls */
  @media (pointer: coarse) {
    .viz-container[data-mermaid-id] .viz-controls {
      opacity: 0.85;
    }
  }

  /* Mermaid wrapper styles */
  .mermaid-wrapper {
    display: flex;
    justify-content: center;
    width: 100%;
    padding: 1rem;
  }

  .mermaid-output {
    width: 100%;
    overflow-x: auto;
    display: flex;
    justify-content: center;
  }

  .mermaid-output :global(svg) {
    max-width: 100%;
    height: auto;
  }

  .mermaid-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80px;
    width: 100%;
  }

  .mermaid-error {
    color: var(--accent);
    text-align: center;
    padding: 1rem;
  }

  /* Code view styles */
  .mermaid-code-view {
    background: var(--surface);
    border-radius: 0.5rem;
  }

  .mermaid-code-view pre {
    margin: 0;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .mermaid-code-view code {
    font-family: var(--font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    color: var(--foreground);
  }

  /* Ensure hidden class works correctly */
  .viz-container[data-mermaid-id] .mermaid-output.hidden {
    display: none !important;
  }

  .viz-container[data-mermaid-id] .mermaid-code-view.hidden {
    display: none !important;
  }
</style>