---
/**
 * Markmap initialization script.
 * Renders markmap mindmaps from ```markmap code blocks with:
 * - Zoom in/out/reset controls
 * - Pan (Shift+drag or middle mouse button)
 * - Fullscreen mode
 * - Hover-to-show toolbar
 * - Code/preview toggle with Shiki highlighting
 * - Theme-aware colors (dark/light mode)
 * - No built-in theme toggle (follows blog theme)
 */
---

<script is:inline>
  // CDN scripts (loaded in dependency order)
  // NOTE: We do NOT load markmap-toolbar — it adds its own theme toggle
  // which conflicts with the blog's theme system. We provide our own toolbar.
  const CDN_SCRIPTS = [
    'https://cdn.jsdelivr.net/npm/d3@7.9.0/dist/d3.min.js',
    'https://cdn.jsdelivr.net/npm/markmap-view@0.18.12/dist/browser/index.js',
  ];

  let loading = false;
  let loaded = false;

  function loadScript(src) {
    return new Promise((resolve, reject) => {
      if (document.querySelector(`script[src="${src}"]`)) {
        resolve();
        return;
      }
      const script = document.createElement('script');
      script.src = src;
      script.onload = () => resolve();
      script.onerror = () => reject(new Error(`Failed to load ${src}`));
      document.head.appendChild(script);
    });
  }

  async function loadAssets() {
    if (loaded) return true;
    if (loading) {
      await new Promise(resolve => {
        const check = () => loaded ? resolve() : setTimeout(check, 50);
        check();
      });
      return true;
    }

    loading = true;
    try {
      for (const src of CDN_SCRIPTS) {
        await loadScript(src);
      }
      loaded = true;
      return true;
    } catch (error) {
      console.error('Markmap load error:', error);
      loading = false;
      return false;
    }
  }

  function getIsDark() {
    return document.documentElement.getAttribute("data-theme") === "dark";
  }

  function escapeHtml(text) {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  function createToolbarHTML() {
    return `
      <div class="viz-controls absolute right-2 bottom-2 z-10 flex items-center gap-1 rounded-lg border border-[var(--viz-border)] bg-[var(--viz-btn-bg)] p-1 opacity-0 shadow-sm backdrop-blur-sm transition-opacity duration-200 group-hover:opacity-100 focus-within:opacity-100">
        <button class="viz-btn viz-zoom-in flex size-7 items-center justify-center rounded-md text-foreground-soft transition-colors hover:bg-[var(--viz-btn-hover)] hover:text-accent" aria-label="Zoom in" title="Zoom in">
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
        </button>
        <button class="viz-btn viz-zoom-out flex size-7 items-center justify-center rounded-md text-foreground-soft transition-colors hover:bg-[var(--viz-btn-hover)] hover:text-accent" aria-label="Zoom out" title="Zoom out">
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" /></svg>
        </button>
        <button class="viz-btn viz-reset flex size-7 items-center justify-center rounded-md text-foreground-soft transition-colors hover:bg-[var(--viz-btn-hover)] hover:text-accent" aria-label="Reset view" title="Reset view">
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" /><path d="M3 3v5h5" /></svg>
        </button>
        <div class="mx-0.5 h-4 w-px bg-[var(--viz-border)]"></div>
        <button class="viz-btn viz-fullscreen flex size-7 items-center justify-center rounded-md text-foreground-soft transition-colors hover:bg-[var(--viz-btn-hover)] hover:text-accent" aria-label="Toggle fullscreen" title="Toggle fullscreen">
          <svg class="viz-fs-enter size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3" /><path d="M21 8V5a2 2 0 0 0-2-2h-3" /><path d="M3 16v3a2 2 0 0 0 2 2h3" /><path d="M16 21h3a2 2 0 0 0 2-2v-3" /></svg>
          <svg class="viz-fs-exit hidden size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3v3a2 2 0 0 1-2 2H3" /><path d="M21 8h-3a2 2 0 0 1-2-2V3" /><path d="M3 16h3a2 2 0 0 1 2 2v3" /><path d="M16 21v-3a2 2 0 0 1 2-2h3" /></svg>
        </button>
        <button class="viz-btn viz-toggle-code flex size-7 items-center justify-center rounded-md text-foreground-soft transition-colors hover:bg-[var(--viz-btn-hover)] hover:text-accent" aria-label="Toggle code view" title="View code">
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" /></svg>
        </button>
      </div>
    `;
  }

  async function render(wrapEl) {
    if (wrapEl.dataset.rendered) return;

    const jsonScripts = wrapEl.querySelectorAll('script[type="application/json"]');
    if (!jsonScripts.length) return;

    const success = await loadAssets();
    if (!success || !window.markmap) {
      wrapEl.innerHTML = '<p class="markmap-error">Failed to load markmap</p>';
      return;
    }

    try {
      const { Markmap, deriveOptions } = window.markmap;
      const root = JSON.parse(jsonScripts[0]?.textContent || '{}');
      const options = jsonScripts[1] ? JSON.parse(jsonScripts[1].textContent || '{}') : {};

      const sourceCode = wrapEl.dataset.source || '';

      const container = document.createElement("div");
      container.className = "viz-container group relative my-6 overflow-hidden rounded-lg border";
      container.style.minHeight = "300px";
      container.setAttribute("data-viz-zoom", "true");
      container.setAttribute("data-viz-fullscreen", "true");
      container.setAttribute("data-viz-type", "markmap");

      const viewport = document.createElement("div");
      viewport.className = "viz-viewport w-full origin-center";
      viewport.style.transform = "scale(1) translate(0px, 0px)";

      const svgOutput = document.createElement("div");
      svgOutput.className = "markmap-svg-output";

      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.style.width = '100%';
      svg.style.height = '400px';
      svgOutput.appendChild(svg);

      const codeView = document.createElement("div");
      codeView.className = "markmap-code-view hidden";
      codeView.innerHTML = `<pre class="text-sm"><code class="language-markdown">${escapeHtml(sourceCode)}</code></pre>`;

      viewport.appendChild(svgOutput);
      container.appendChild(viewport);
      container.appendChild(codeView);

      const toolbarContainer = document.createElement("div");
      toolbarContainer.innerHTML = createToolbarHTML();
      container.appendChild(toolbarContainer.firstElementChild);

      wrapEl.parentNode?.replaceChild(container, wrapEl);

      const mm = Markmap.create(svg, deriveOptions(options), root);

      // Setup code toggle (Shiki loaded lazily via module script)
      container.querySelector(".viz-toggle-code")?.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        // Dispatch custom event for the module script to handle
        container.dispatchEvent(new CustomEvent("viz-toggle-code", { bubbles: true }));
      });

      // Adjust height
      const resize = () => {
        const h = Math.max(mm.state.rect.y2 || 300, 200);
        svg.style.height = h + 'px';
        mm.fit();
      };
      new ResizeObserver(resize).observe(container);
      setTimeout(resize, 100);

      container.dataset.rendered = 'true';

      // Initialize viz controls via event
      requestAnimationFrame(() => {
        window.dispatchEvent(new CustomEvent("viz:init"));
      });
    } catch (error) {
      console.error('Markmap render error:', error);
      wrapEl.innerHTML = `<p class="markmap-error">Render error: ${error instanceof Error ? error.message : "unknown"}</p>`;
    }
  }

  function renderAll() {
    document.querySelectorAll('.markmap-wrap').forEach(el => {
      if (el.dataset.rendered) return;
      const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            obs.unobserve(entry.target);
            render(entry.target);
          }
        });
      }, { rootMargin: '200px' });
      observer.observe(el);
    });
  }

  function updateTheme(isDark) {
    document.documentElement.classList.toggle('markmap-dark', isDark);

    document.querySelectorAll('.viz-container[data-viz-type="markmap"]').forEach(container => {
      const svg = container.querySelector('svg');
      if (!svg) return;

      const textElements = svg.querySelectorAll('text');
      textElements.forEach(el => {
        el.style.fill = 'var(--foreground)';
      });

      const foreignObjects = svg.querySelectorAll('foreignObject');
      foreignObjects.forEach(fo => {
        const body = fo.querySelector('.markmap-foreign');
        if (body) {
          body.style.color = 'var(--foreground)';
        }
      });
    });
  }

  window.addEventListener('themechange', (e) => {
    const detail = e?.detail;
    const isDark = detail?.isDark ?? getIsDark();
    updateTheme(isDark);
  });

  function init() {
    updateTheme(getIsDark());
    renderAll();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>

<!-- Module script for Shiki highlighting and code toggle logic -->
<script>
  import { initVizContainers } from "../../scripts/viz-controls";

  let shikiHighlighter: import("shiki").Highlighter | null = null;

  document.addEventListener("astro:page-load", initVizContainers);
  window.addEventListener("viz:init", initVizContainers);

  function getIsDark(): boolean {
    return document.documentElement.getAttribute("data-theme") === "dark";
  }

  async function loadShikiHighlighter() {
    if (shikiHighlighter) return shikiHighlighter;
    const shiki = await import("shiki");
    shikiHighlighter = await shiki.createHighlighter({
      themes: ["night-owl", "github-light"],
      langs: ["markdown"],
    });
    return shikiHighlighter;
  }

  // Listen for code toggle events dispatched by the inline script
  document.addEventListener("viz-toggle-code", async (e: Event) => {
    const container = (e.target as HTMLElement).closest(".viz-container[data-viz-type='markmap']");
    if (!container) return;

    const svgOutput = container.querySelector<HTMLElement>(".markmap-svg-output");
    const codeView = container.querySelector<HTMLElement>(".markmap-code-view");
    const toggleBtn = container.querySelector<HTMLElement>(".viz-toggle-code");
    if (!svgOutput || !codeView) return;

    const isShowingCode = !codeView.classList.contains("hidden");

    if (isShowingCode) {
      // Switch back to diagram
      svgOutput.classList.remove("hidden");
      codeView.classList.add("hidden");
      const viewport = container.querySelector<HTMLElement>(".viz-viewport");
      if (viewport) viewport.style.display = "";
      codeView.style.maxHeight = "";
      codeView.style.flex = "";
      codeView.style.minHeight = "";
      if (toggleBtn) toggleBtn.title = "View code";
    } else {
      // Switch to code view
      svgOutput.classList.add("hidden");
      codeView.classList.remove("hidden");
      const viewport = container.querySelector<HTMLElement>(".viz-viewport");
      if (viewport) viewport.style.display = "none";
      if (toggleBtn) toggleBtn.title = "View diagram";

      // Check if in fullscreen
      const isFs = document.fullscreenElement === container;
      if (isFs) {
        codeView.style.maxHeight = "none";
        codeView.style.flex = "1";
        codeView.style.minHeight = "0";
      }

      // Apply Shiki highlighting if not already done
      const sourceCode = (container.closest("[data-source]") as HTMLElement)?.dataset.source
        || codeView.querySelector("code")?.textContent || "";

      try {
        const highlighter = await loadShikiHighlighter();
        const isDark = getIsDark();
        const theme = isDark ? "night-owl" : "github-light";
        const html = highlighter.codeToHtml(sourceCode, {
          lang: "markdown",
          theme,
        });
        // Strip Shiki's inline style attributes from <pre> to prevent background/shadow overlay
        const cleaned = html.replace(/(<pre\s[^>]*?)style="[^"]*"/g, '$1');
        codeView.innerHTML = cleaned;
      } catch {
        // Shiki highlighting failed — keep the plain code view
      }
    }
  });

  // Re-highlight on theme change
  window.addEventListener("themechange", async () => {
    document.querySelectorAll<HTMLElement>(".viz-container[data-viz-type='markmap']").forEach(async (container) => {
      const codeView = container.querySelector<HTMLElement>(".markmap-code-view");
      if (!codeView || codeView.classList.contains("hidden")) return;

      const sourceCode = codeView.querySelector("code")?.textContent || "";
      if (!sourceCode) return;

      try {
        const highlighter = await loadShikiHighlighter();
        const isDark = getIsDark();
        const theme = isDark ? "night-owl" : "github-light";
        const html = highlighter.codeToHtml(sourceCode, {
          lang: "markdown",
          theme,
        });
        // Strip Shiki's inline style attributes from <pre> to prevent background/shadow overlay
        const cleaned = html.replace(/(<pre\s[^>]*?)style="[^"]*"/g, '$1');
        codeView.innerHTML = cleaned;
      } catch {
        // Re-highlight failed — keep existing content
      }
    });
  });

  // Update code view layout when fullscreen changes
  document.addEventListener("fullscreenchange", () => {
    document.querySelectorAll<HTMLElement>(".viz-container[data-viz-type='markmap']").forEach(container => {
      const codeView = container.querySelector<HTMLElement>(".markmap-code-view");
      if (!codeView || codeView.classList.contains("hidden")) return;

      const isFs = document.fullscreenElement === container;
      const viewport = container.querySelector<HTMLElement>(".viz-viewport");
      if (isFs) {
        codeView.style.maxHeight = "none";
        codeView.style.flex = "1";
        codeView.style.minHeight = "0";
        if (viewport) viewport.style.display = "none";
      } else {
        codeView.style.maxHeight = "";
        codeView.style.flex = "";
        codeView.style.minHeight = "";
        if (viewport) viewport.style.display = "";
      }
    });
  });
</script>

<style is:global>
  /* Markmap container styles */
  .viz-container[data-viz-type="markmap"] {
    background: var(--viz-bg);
    border-color: var(--viz-border);
    transition:
      background-color 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      border-color 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .viz-container[data-viz-type="markmap"]:fullscreen {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    background: var(--background);
  }

  .viz-container[data-viz-type="markmap"]:fullscreen .viz-viewport {
    position: absolute;
    inset: 0;
    overflow: auto;
    display: flex;
    flex-direction: column;
  }

  .viz-container[data-viz-type="markmap"]:fullscreen .viz-viewport > * {
    flex: 1;
    min-height: 0;
    min-width: 0;
  }

  .viz-container[data-viz-type="markmap"]:fullscreen .viz-controls {
    opacity: 1 !important;
    pointer-events: auto;
  }

  /* Hover behavior for controls */
  .viz-container[data-viz-type="markmap"] .viz-controls {
    opacity: 0;
    transition: opacity var(--transition-base) var(--ease-out-expo);
  }

  .viz-container[data-viz-type="markmap"]:hover .viz-controls,
  .viz-container[data-viz-type="markmap"] .viz-controls:focus-within {
    opacity: 1;
  }

  /* Touch devices - always show controls */
  @media (pointer: coarse) {
    .viz-container[data-viz-type="markmap"] .viz-controls {
      opacity: 0.85;
    }
  }

  /* Markmap SVG output wrapper */
  .markmap-svg-output {
    width: 100%;
    padding: 1rem;
  }

  .markmap-svg-output > svg {
    width: 100%;
    margin: 0;
    padding: 0;
  }

  /* Markmap error */
  .markmap-error {
    color: var(--accent);
    text-align: center;
    padding: 1rem;
  }

  /* Code view styles — clean, no shadow, scrollable */
  .markmap-code-view {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: 1rem;
    overflow-y: auto;
    overflow-x: auto;
  }

  /* Override Shiki's built-in background/shadow */
  .markmap-code-view .shiki {
    background: none !important;
    box-shadow: none !important;
    border: none !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  .markmap-code-view pre {
    margin: 0;
    white-space: pre;
    overflow: visible;
    line-height: 1.6;
    background: none !important;
    box-shadow: none !important;
  }

  .markmap-code-view code {
    font-family: var(--font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace);
    font-size: 0.875rem;
    tab-size: 2;
  }

  /* Shiki light/dark token colors */
  .markmap-code-view {
    color: var(--shiki-light, var(--foreground));
  }
  .markmap-code-view span {
    color: var(--shiki-light, inherit);
  }
  html[data-theme="dark"] .markmap-code-view {
    color: var(--shiki-dark, var(--foreground));
  }
  html[data-theme="dark"] .markmap-code-view span {
    color: var(--shiki-dark, inherit);
  }

  /* Ensure hidden class works correctly */
  .viz-container[data-viz-type="markmap"] .markmap-svg-output.hidden {
    display: none !important;
  }

  .viz-container[data-viz-type="markmap"] .markmap-code-view.hidden {
    display: none !important;
  }

  /* When code view is visible, hide viewport */
  .viz-container[data-viz-type="markmap"]:has(.markmap-code-view:not(.hidden)) .viz-viewport {
    display: none !important;
  }

  /* Fullscreen code view: fill entire screen */
  .viz-container[data-viz-type="markmap"]:fullscreen:has(.markmap-code-view:not(.hidden)) .markmap-code-view {
    flex: 1;
    min-height: 0;
    max-height: none;
    border-radius: 0;
  }

  /* Dark mode markmap SVG colors */
  html.markmap-dark .markmap {
    --markmap-text-color: var(--foreground);
    --markmap-code-bg: var(--muted);
    --markmap-circle-open-bg: var(--card);
  }

  /* Force markmap SVG text to use theme colors */
  .viz-container[data-viz-type="markmap"] svg text {
    fill: var(--foreground) !important;
  }

  /* Hide the built-in mm-toolbar */
  .mm-toolbar {
    display: none !important;
  }

  /* Legacy .markmap-wrap styles */
  .markmap-wrap {
    position: relative;
    width: 100%;
    min-height: 300px;
    margin: 1.5rem 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .markmap-wrap > svg {
    width: 100%;
    margin: 0;
    padding: 0;
  }
</style>