  "questionPatterns": {
    "count": {
      "description": "数量统计类问题",
      "patterns": ["有多少", "几个", "数量", "How many", "count"],
      "answerStyle": "第一句先说数字或「至少 X」，避免伪精确"
    },
    "fact": {
      "description": "事实陈述类问题",
      "patterns": ["是什么", "怎么", "是什么时候", "What is", "How to", "When"],
      "answerStyle": "先给结论，再补依据，如有直接对应的文章点明标题或给出链接"
    },
    "list": {
      "description": "列表枚举类问题",
      "patterns": ["有哪些", "支持什么", "列举", "What are", "list"],
      "answerStyle": "直接列 2-6 项同一维度的内容"
    },
    "recommendation": {
      "description": "推荐建议类问题",
      "patterns": ["推荐", "建议", "哪个好", "recommend", "suggest"],
      "answerStyle": "先给 2-4 个推荐项，再说明理由"
    },
    "opinion": {
      "description": "观点看法类问题",
      "patterns": ["你怎么看", "哪个更好", "优缺点", "opinion", "vs"],
      "answerStyle": "先「我觉得/我的看法是」，再用 2-3 个观点展开"
    },
    "unknown": {
      "description": "隐私未知类问题",
      "patterns": ["你的", "私人", "家庭", "收入", "住址"],
      "answerStyle": "第一句必须包含「未公开」或「不提供」，1-2 句收尾"
    }
  },

