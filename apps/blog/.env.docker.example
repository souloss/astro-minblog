# =============================================================================
# Astro Minimax Blog - Docker Deployment Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# Site Configuration
DOMAIN=example.com
SITE_URL=https://example.com
SITE_NAME=Astro Minimax Blog
SITE_AUTHOR=Your Name
CADDY_EMAIL=admin@example.com

# Waline Comments (Optional - for self-hosted)
# Enable with: docker compose --profile waline up -d
WALINE_JWT_TOKEN=your-secure-jwt-token-min-32-chars
WALINE_SMTP_SERVICE=
WALINE_SMTP_USER=
WALINE_SMTP_PASS=
WALINE_AUTHOR_EMAIL=

# Umami Analytics (Optional - for self-hosted)
# Enable with: docker compose --profile umami up -d
UMAMI_DB_PASSWORD=your-secure-db-password
UMAMI_APP_SECRET=your-secure-app-secret-min-32-chars

# AI Configuration (Optional - for Cloudflare deployment)
# These are used when deploying to Cloudflare Pages
AI_BINDING_NAME=minimaxAI
AI_WORKERS_MODEL=@cf/zai-org/glm-4.7-flash
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your-api-key
AI_MODEL=gpt-4o-mini

# Notification Configuration (Optional)
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_RESEND_API_KEY=
NOTIFY_RESEND_FROM=
NOTIFY_RESEND_TO=